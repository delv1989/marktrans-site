---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { worksPages } from '../../../data/works-pages';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return worksPages.map((w) => ({
    params: { slug: w.slug },
    props: { work: w },
  }));
};

const { work } = Astro.props;
const title = `${work.name} Київ · MARKTRANS`;
const description = work.description.slice(0, 160);
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: 'Головна', href: '/uk/' },
    { label: 'Роботи', href: '/uk/roboty/' },
    { label: work.name }
  ]} />

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="aspect-[4/3] rounded-sm overflow-hidden bg-mt-bg-1 border border-mt-divider">
          <img src={work.image} alt={work.alt} class="w-full h-full object-cover brightness-80 contrast-[1.1]" loading="lazy" />
        </div>
        <div class="flex flex-col justify-center">
          <div class="flex items-center gap-3 mb-6"><span class="block w-8 h-0.5 bg-mt-accent"></span><span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Послуга</span></div>
          <h1 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight leading-none mb-6">
            {work.h1.split('\n').map((l: string, i: number) => <>{i > 0 && <br/>}{l}</>)}
          </h1>
          <p class="text-base text-mt-secondary leading-relaxed mb-8 max-w-[560px]">{work.description}</p>
          <div class="font-mono font-black text-xl text-mt-accent mb-8">{work.price}</div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/uk/kontakty/" class="btn-primary justify-center sm:justify-start">Замовити огляд →</a>
            <a href="tel:+380504204229" class="btn-secondary justify-center sm:justify-start">Подзвонити</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-2xl md:text-4xl uppercase tracking-tight mb-10">Етапи робіт</h2>
      <div class="relative pl-8 md:pl-12 border-l-2 border-mt-accent space-y-8 max-w-[640px]">
        {work.stages.map((stage, i) => (
          <div class="relative">
            <div class="absolute -left-[calc(2rem+5px)] md:-left-[calc(3rem+5px)] top-1 w-2.5 h-2.5 bg-mt-accent rounded-full"></div>
            <div class="font-mono font-black text-lg text-mt-accent leading-none mb-1">{String(i + 1).padStart(2, '0')}</div>
            <p class="text-sm text-mt-secondary">{stage}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-2xl md:text-4xl uppercase tracking-tight mb-10">Техніка</h2>
      <ul class="space-y-4 max-w-[640px]">
        {work.equipment.map((eq) => (
          <li class="flex items-start gap-3 text-sm text-mt-secondary"><span class="font-mono font-black text-mt-accent mt-0.5">→</span><span>{eq}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <FAQ items={work.faq} title="Запитання" />

  <CTABanner
    title={`${work.name}?`}
    subtitle="Безкоштовний кошторис після огляду об'єкта."
    buttonText="Замовити огляд →"
    buttonHref="/uk/kontakty/"
  />
</PageLayout>
