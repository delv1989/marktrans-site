---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { contacts } from '../../data/navigation';

const title = 'Контакти MARKTRANS — телефон, адреса, карта · Київ';
const description = 'MARKTRANS працює 24/7. Телефон: +38 050 420 42 29. Адреса: Київ, вул. Жилянська, 101. Telegram: @marktrans_bot. Email: service@marktrans.com.ua.';
const addr = contacts.address.uk;

const contactCards = [
  { icon: 'phone', label: 'Телефон', value: contacts.phones[0], subvalue: contacts.phones[1], href: `tel:${contacts.phonesRaw[0]}`, sub: 'Цілодобово · Пн-Нд', btnText: 'Подзвонити', btnColor: 'primary' },
  { icon: 'tg', label: 'Telegram', value: '@marktrans_bot', href: 'https://t.me/marktrans_bot', target: '_blank', sub: 'Миттєві замовлення', btnText: 'Відкрити бот', btnColor: 'primary' },
  { icon: 'mail', label: 'Email', value: contacts.email, href: `mailto:${contacts.email}`, sub: 'Відповідь протягом 1 години', btnText: 'Написати', btnColor: 'secondary' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: 'Головна', href: '/uk/' },
    { label: 'Контакти' }
  ]} />

  <!-- Header -->
  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="block w-8 h-0.5 bg-mt-accent"></span>
        <span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Зв'яжіться з нами</span>
      </div>
      <h1
        class="font-display font-black uppercase mb-6"
        style="font-size: clamp(56px, 12vw, 144px); line-height: 0.85; letter-spacing: -0.04em;"
      >
        КОНТАКТИ
      </h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[720px] leading-relaxed">
        MARKTRANS працює 24/7. Диспетчер приймає замовлення цілодобово.
        Офіс за адресою: {addr.city}, {addr.street}.
      </p>
    </div>
  </section>

  <!-- Status banner -->
  <div class="bg-mt-accent py-3 px-6">
    <div class="max-w-[1440px] mx-auto flex items-center justify-center gap-3 font-mono text-sm font-bold text-mt-accent-contrast">
      <span class="w-2 h-2 bg-mt-accent-contrast rounded-full animate-pulse"></span>
      Відкрито зараз · Диспетчер на зв'язку
    </div>
  </div>

  <!-- Contact cards -->
  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-mt-divider border border-mt-divider">
        {contactCards.map((card) => (
          <div class="bg-mt-bg-1 p-8 md:p-10 flex flex-col">
            <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest mb-4">{card.label}</div>
            <div class="font-mono font-black text-xl md:text-2xl text-mt-accent leading-tight mb-1">{card.value}</div>
            {card.subvalue && <div class="font-mono font-bold text-base text-mt-text mb-2">{card.subvalue}</div>}
            <div class="text-xs text-mt-tertiary mb-6">{card.sub}</div>
            <a
              href={card.href}
              target={card.target}
              rel={card.target ? 'noopener noreferrer' : undefined}
              class:list={[
                'mt-auto w-full text-center py-3.5 font-display font-black text-sm uppercase tracking-wider rounded-xs transition-all',
                card.btnColor === 'primary'
                  ? 'bg-mt-accent text-mt-accent-contrast hover:bg-mt-accent-hover'
                  : 'bg-transparent text-mt-text border-2 border-mt-divider hover:border-mt-accent hover:text-mt-accent',
              ]}
            >
              {card.btnText}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Address + Map -->
  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Address & Legal -->
        <div>
          <h2 class="font-display font-black text-2xl uppercase tracking-tight mb-8">Адреса та реквізити</h2>
          <div class="space-y-4 font-mono text-sm">
            <div class="flex items-baseline gap-3">
              <span class="text-mt-tertiary text-[10px] uppercase tracking-widest min-w-[80px]">Адреса</span>
              <span class="font-bold">{addr.city}, {addr.street}, {addr.zip}</span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-mt-tertiary text-[10px] uppercase tracking-widest min-w-[80px]">Години</span>
              <span class="font-bold">{contacts.hours.uk}</span>
            </div>
            <div class="border-t border-mt-divider my-6"></div>
            {contacts.phones.map((phone, i) => (
              <div class="flex items-baseline gap-3">
                <span class="text-mt-tertiary text-[10px] uppercase tracking-widest min-w-[80px]">{i === 0 ? 'Телефон' : ''}</span>
                <a href={`tel:${contacts.phonesRaw[i]}`} class="font-bold hover:text-mt-accent transition-colors">{phone}</a>
              </div>
            ))}
            <div class="flex items-baseline gap-3">
              <span class="text-mt-tertiary text-[10px] uppercase tracking-widest min-w-[80px]">Email</span>
              <a href={`mailto:${contacts.email}`} class="font-bold hover:text-mt-accent transition-colors break-all">{contacts.email}</a>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div>
          <h2 class="font-display font-black text-2xl uppercase tracking-tight mb-8">На мапі</h2>
          <div class="relative aspect-[4/3] border border-mt-divider overflow-hidden bg-mt-bg-1">
            <div class="absolute top-4 left-4 z-10 flex items-center gap-2 bg-mt-bg px-4 py-2.5 border border-mt-divider pointer-events-none">
              <span class="w-2 h-2 bg-mt-accent rounded-full animate-pulse"></span>
              <span class="font-mono text-[10px] text-mt-accent uppercase tracking-widest">MARKTRANS · Офіс</span>
            </div>
            <iframe
              src="https://maps.google.com/maps?q=%D0%9A%D0%B8%D1%97%D0%B2%20%D0%B2%D1%83%D0%BB.%20%D0%96%D0%B8%D0%BB%D1%8F%D0%BD%D1%81%D1%8C%D0%BA%D0%B0%20101&t=&z=15&ie=UTF8&iwloc=&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="MARKTRANS на мапі"
              class="w-full h-full border-0"
              style="filter: grayscale(100%) invert(92%) hue-rotate(180deg) contrast(85%);"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Delivery zones -->
  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight mb-12">Зона доставки</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-mt-divider border border-mt-divider">
        {[
          { range: 'До 16 км', price: '3500 ₴', note: 'Базовий виїзд' },
          { range: '17-40 км', price: '+220 ₴/км', note: 'Київська область' },
          { range: '41-200 км', price: '+200 ₴/км', note: 'Далека область' },
        ].map((zone) => (
          <div class="bg-mt-bg p-8 md:p-10 text-center">
            <div class="font-display font-black text-lg uppercase tracking-tight mb-2">{zone.range}</div>
            <div class="font-mono font-black text-3xl md:text-4xl text-mt-accent leading-none mb-3">{zone.price}</div>
            <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest">{zone.note}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
