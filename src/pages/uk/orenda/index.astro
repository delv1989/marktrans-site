---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';

const entries = await getCollection('equipment', ({ data }) => data.locale === 'uk');
const sorted = entries.sort((a, b) => a.data.title.localeCompare(b.data.title, 'uk'));

const title = 'Оренда спецтехніки Київ — самоскид, бульдозер, навантажувач · MARKTRANS';
const description = 'Оренда самоскидів, бульдозерів, навантажувачів, гідромолотів. Водій + ПММ включено. Київ і Київська область.';

const faq = [
  { question: 'Яка мінімальна тривалість оренди?', answer: 'Мінімальне замовлення — 4 години погодинної оренди або 1 повний рейс.' },
  { question: 'Що включено у вартість?', answer: 'Водій-оператор, паливо (ПММ), технічне обслуговування, страхування.' },
  { question: 'Чи працюєте у вихідні?', answer: 'Так, працюємо 7 днів на тиждень. Диспетчер доступний 24/7.' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'Головна', href: '/uk/' }, { label: 'Оренда спецтехніки' }]} />

  <section class="py-16 md:py-24 lg:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6"><span class="block w-8 h-0.5 bg-mt-accent"></span><span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Техніка</span></div>
      <h1 class="font-display font-black uppercase mb-6" style="font-size: clamp(48px, 10vw, 120px); line-height: 0.88; letter-spacing: -0.03em;">ОРЕНДА<br/><span class="text-mt-accent">СПЕЦТЕХНІКИ</span></h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[720px] leading-relaxed">Власний парк техніки: самоскиди, бульдозери, навантажувачі, екскаватори, гідромолоти. Водій + ПММ включені.</p>
    </div>
  </section>

  <section class="border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24">
      <SectionHeader eyebrow="ТЕХНІКА" titleLine1="КАТАЛОГ" titleAccent="ТЕХНІКИ" meta={[`${sorted.length} ПОЗИЦІЙ`]} />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-mt-divider">
        {sorted.map((entry) => (
          <a href={`/uk/orenda/${entry.data.slug}/`} class="group block bg-mt-bg-1 border-r border-b border-mt-divider transition-colors hover:bg-mt-bg-2 hover:border-mt-accent">
            {entry.data.image && (<div class="h-48 md:h-56 overflow-hidden"><img src={entry.data.image} alt={entry.data.title} loading="lazy" class="w-full h-full object-cover brightness-75 grayscale-[30%] transition-transform duration-700 group-hover:scale-[1.06]" /></div>)}
            <div class="p-6 md:p-8">
              <h3 class="font-display font-black text-lg uppercase tracking-tight mb-2">{entry.data.title}</h3>
              {entry.data.priceFrom && (<div class="flex items-baseline gap-2"><span class="font-mono font-black text-2xl text-mt-accent">{entry.data.priceFrom} ₴</span><span class="font-mono text-[11px] text-mt-tertiary uppercase tracking-widest">/ год</span></div>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faq} title="Запитання про оренду" />
  <CTABanner title="Потрібна техніка?" subtitle="Подзвоніть — підберемо машину." buttonText="Подзвонити →" buttonHref="tel:+380504204229" />
</PageLayout>
