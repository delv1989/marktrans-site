---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { equipmentPages } from '../../../data/equipment-pages';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return equipmentPages.map((e) => ({
    params: { slug: e.slug },
    props: { equip: e },
  }));
};

const { equip } = Astro.props;
const title = `${equip.name} Київ — ${equip.priceFrom} · MARKTRANS`;
const description = equip.description.slice(0, 160);
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: 'Головна', href: '/uk/' },
    { label: 'Оренда', href: '/uk/orenda/' },
    { label: equip.name }
  ]} />

  <section class="relative min-h-[50vh] flex items-center py-16 md:py-24 overflow-hidden" style={`background: linear-gradient(135deg, rgba(15,15,15,0.9) 0%, rgba(15,15,15,0.5) 100%), url('${equip.image}') center/cover;`}>
    <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-12 w-full">
      <h1 class="font-display font-black uppercase mb-6" style="font-size: clamp(48px, 9vw, 100px); line-height: 0.88; letter-spacing: -0.03em;">
        {equip.h1.split('\n').map((l: string, i: number) => <>{i > 0 && <br/>}{i === equip.h1.split('\n').length - 1 ? <span class="text-mt-accent">{l}</span> : l}</>)}
      </h1>
      <p class="text-base md:text-lg text-[#DDD] max-w-[640px] leading-relaxed mb-8">{equip.description}</p>
      <div class="font-mono font-black text-3xl text-mt-accent mb-8">{equip.priceFrom}</div>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/uk/kontakty/" class="btn-primary justify-center sm:justify-start">Замовити →</a>
        <a href="tel:+380504204229" class="btn-secondary justify-center sm:justify-start">Подзвонити</a>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-2xl md:text-4xl uppercase tracking-tight mb-10">Характеристики</h2>
      <div class="border border-mt-divider divide-y divide-mt-divider max-w-[640px]">
        {equip.specs.map(([label, value]) => (
          <div class="flex"><div class="w-2/5 px-4 py-3 font-mono text-sm text-mt-tertiary border-r border-mt-divider">{label}</div><div class="w-3/5 px-4 py-3 font-mono text-sm font-bold">{value}</div></div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-2xl md:text-4xl uppercase tracking-tight mb-10">Для чого підходить</h2>
      <ul class="space-y-4 max-w-[640px]">
        {equip.uses.map((use) => (
          <li class="flex items-start gap-3 text-sm text-mt-secondary"><span class="font-mono font-black text-mt-accent mt-0.5">→</span><span>{use}</span></li>
        ))}
      </ul>
    </div>
  </section>

  <FAQ items={equip.faq} title="Запитання" />

  <CTABanner
    title={`${equip.name}?`}
    subtitle="Подзвоніть — підберемо техніку та розрахуємо вартість."
    buttonText="Подзвонити →"
    buttonHref="tel:+380504204229"
  />
</PageLayout>
