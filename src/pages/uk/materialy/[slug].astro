---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { shchebenProducts, faqShcheben } from '../../../data/products';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return shchebenProducts.map((p) => ({
    params: { slug: p.slug },
    props: { product: p },
  }));
};

const { product } = Astro.props;

const title = `${product.name} — ${product.price} ₴/${product.unit} з доставкою · MARKTRANS`;
const description = `${product.name}${product.fraction ? ` фракції ${product.fraction}` : ''}. Ціна ${product.price} ₴/${product.unit}. Доставка самоскидом ACTROS у день замовлення. Київ і Київська область.`;

// Related products — все крім поточного, перші 3
const related = shchebenProducts.filter((p) => p.slug !== product.slug).slice(0, 3);
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: 'Головна', href: '/uk/' },
    { label: 'Матеріали', href: '/uk/materialy/' },
    { label: 'Щебінь', href: '/uk/materialy/shcheben/' },
    { label: product.name }
  ]} />

  <!-- Product header -->
  <section class="py-12 md:py-20 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Image -->
        <div class="aspect-[4/3] rounded-sm overflow-hidden bg-mt-bg-1 border border-mt-divider">
          <img src={product.image} alt={product.alt} class="w-full h-full object-cover brightness-80 contrast-[1.1]" />
        </div>

        <!-- Info -->
        <div class="flex flex-col justify-center">
          {product.badge && (
            <span class="inline-block w-fit mb-4 px-3 py-1 bg-mt-accent/10 border border-mt-accent text-mt-accent font-mono text-[10px] uppercase tracking-widest rounded-xs">
              {product.badge}
            </span>
          )}
          <h1 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight leading-none mb-4">
            {product.name}
          </h1>
          {product.fraction && (
            <div class="font-mono text-sm text-mt-tertiary uppercase tracking-widest mb-2">Фракція {product.fraction}</div>
          )}
          {product.spec && (
            <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest mb-8">{product.spec}</div>
          )}

          <p class="text-base text-mt-secondary leading-relaxed mb-8 max-w-[560px]">
            {description}
          </p>

          <!-- Price -->
          <div class="flex items-baseline gap-4 mb-8 pb-8 border-b border-mt-divider">
            <span class="font-mono font-black text-5xl md:text-6xl text-mt-accent leading-none tracking-tight">{product.price} ₴</span>
            <span class="font-mono text-sm text-mt-tertiary uppercase tracking-widest">/ {product.unit}</span>
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/uk/kontakty/" class="btn-primary justify-center">Замовити доставку →</a>
            <a href="tel:+380504204229" class="btn-secondary justify-center">Подзвонити</a>
          </div>

          <!-- Delivery info -->
          <div class="mt-8 flex flex-wrap gap-6 font-mono text-xs text-mt-tertiary uppercase tracking-widest">
            <span>Доставка сьогодні</span>
            <span>Київ + область</span>
            <span>Мін. 1 тонна</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick specs -->
  {product.fraction && (
    <section class="border-b border-mt-divider">
      <div class="max-w-[1440px] mx-auto grid grid-cols-2 md:grid-cols-4">
        {[
          { v: '1400', l: 'КГ/М³ ЩІЛЬНІСТЬ' },
          { v: 'F300', l: 'МОРОЗОСТІЙКІСТЬ' },
          { v: '≤15%', l: 'ЛЕЩАДНІСТЬ' },
          { v: 'М1200', l: 'МАРКА МІЦНОСТІ' },
        ].map((s) => (
          <div class="px-6 py-8 border-r border-b border-mt-divider last:border-r-0 text-center">
            <div class="font-mono font-black text-2xl md:text-3xl text-mt-accent leading-none mb-2">{s.v}</div>
            <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest">{s.l}</div>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Related products -->
  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-2xl md:text-4xl uppercase tracking-tight mb-10">Інші фракції</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-mt-divider border border-mt-divider">
        {related.map((p) => (
          <a href={`/uk/materialy/${p.slug}/`} class="bg-mt-bg-1 p-6 md:p-8 hover:bg-mt-bg-2 transition-colors block">
            <div class="font-display font-black text-lg uppercase tracking-tight mb-2">{p.name}</div>
            {p.spec && <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest mb-4">{p.spec}</div>}
            <div class="font-mono font-black text-2xl text-mt-accent">{p.price} ₴ <span class="text-sm text-mt-tertiary">/ {p.unit}</span></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faqShcheben.slice(0, 4)} title="Запитання про щебінь" />

  <CTABanner
    title={`${product.name} з доставкою`}
    subtitle={`Від ${product.price} ₴/${product.unit}. Доставка самоскидом ACTROS.`}
    buttonText="Замовити →"
    buttonHref="/uk/kontakty/"
  />
</PageLayout>
