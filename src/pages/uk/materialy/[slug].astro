---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { shchebenProducts, faqShcheben } from '../../../data/products';
import { allMaterials, type MaterialPage } from '../../../data/all-materials';
import type { GetStaticPaths } from 'astro';

// Combine both sources: shcheben products + other materials
export const getStaticPaths: GetStaticPaths = () => {
  const shchebenPaths = shchebenProducts.map((p) => ({
    params: { slug: p.slug },
    props: { type: 'product' as const, product: p, material: null as MaterialPage | null },
  }));

  const materialPaths = allMaterials.map((m) => ({
    params: { slug: m.slug },
    props: { type: 'material' as const, product: null, material: m },
  }));

  return [...shchebenPaths, ...materialPaths];
};

const { type, product, material } = Astro.props;

// Unified data
const name = type === 'product' ? product!.name : material!.name;
const priceFrom = type === 'product' ? product!.price : material!.priceFrom;
const unit = type === 'product' ? product!.unit : material!.unit;
const image = type === 'product' ? product!.image : material!.image;
const alt = type === 'product' ? product!.alt : material!.alt;
const description = type === 'product'
  ? `${name}${product!.fraction ? ` фракції ${product!.fraction}` : ''}. Ціна ${priceFrom} ₴/${unit}. Доставка самоскидом ACTROS у день замовлення.`
  : material!.description;
const faq = type === 'product' ? faqShcheben.slice(0, 4) : material!.faq;
const parentLabel = type === 'product' ? 'Щебінь' : 'Матеріали';
const parentHref = type === 'product' ? '/uk/materialy/shcheben/' : '/uk/materialy/';
const title = `${name} — від ${priceFrom} ₴/${unit} з доставкою · MARKTRANS`;
const metaDesc = description.slice(0, 160);

const related = type === 'product'
  ? shchebenProducts.filter((p) => p.slug !== product!.slug).slice(0, 3)
  : [];
---

<PageLayout title={title} description={metaDesc}>
  <Breadcrumbs items={[
    { label: 'Головна', href: '/uk/' },
    { label: 'Матеріали', href: '/uk/materialy/' },
    { label: parentLabel, href: parentHref },
    { label: name }
  ]} />

  <section class="py-12 md:py-20 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div class="aspect-[4/3] rounded-sm overflow-hidden bg-mt-bg-1 border border-mt-divider">
          <img src={image} alt={alt} class="w-full h-full object-cover brightness-80 contrast-[1.1]" />
        </div>
        <div class="flex flex-col justify-center">
          {type === 'product' && product!.badge && (
            <span class="inline-block w-fit mb-4 px-3 py-1 bg-mt-accent/10 border border-mt-accent text-mt-accent font-mono text-[10px] uppercase tracking-widest rounded-xs">{product!.badge}</span>
          )}
          <h1 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight leading-none mb-4">{name}</h1>
          {type === 'product' && product!.fraction && (
            <div class="font-mono text-sm text-mt-tertiary uppercase tracking-widest mb-2">Фракція {product!.fraction}</div>
          )}
          <p class="text-base text-mt-secondary leading-relaxed mb-8 max-w-[560px]">{description}</p>
          <div class="flex items-baseline gap-4 mb-8 pb-8 border-b border-mt-divider">
            <span class="font-mono font-black text-5xl md:text-6xl text-mt-accent leading-none tracking-tight">{priceFrom} ₴</span>
            <span class="font-mono text-sm text-mt-tertiary uppercase tracking-widest">/ {unit}</span>
          </div>
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="/uk/kontakty/" class="btn-primary justify-center">Замовити доставку →</a>
            <a href="tel:+380504204229" class="btn-secondary justify-center">Подзвонити</a>
          </div>
          <div class="mt-8 flex flex-wrap gap-6 font-mono text-xs text-mt-tertiary uppercase tracking-widest">
            <span>Доставка сьогодні</span><span>Київ + область</span><span>Мін. 1 тонна</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Specs table for materials */}
  {type === 'material' && material!.specs.length > 0 && (
    <section class="py-16 md:py-24 border-b border-mt-divider">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12">
        <h2 class="font-display font-black text-2xl md:text-4xl uppercase tracking-tight mb-10">Характеристики</h2>
        <div class="border border-mt-divider divide-y divide-mt-divider max-w-[640px]">
          {material!.specs.map(([label, value]) => (
            <div class="flex"><div class="w-2/5 px-4 py-3 font-mono text-sm text-mt-tertiary border-r border-mt-divider">{label}</div><div class="w-3/5 px-4 py-3 font-mono text-sm font-bold text-mt-accent">{value}</div></div>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* Uses */}
  {type === 'material' && (
    <section class="py-16 md:py-24 border-b border-mt-divider">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12">
        <h2 class="font-display font-black text-2xl md:text-4xl uppercase tracking-tight mb-10">Сфери застосування</h2>
        <ul class="space-y-4 max-w-[640px]">
          {material!.uses.map((use) => (
            <li class="flex items-start gap-3 text-sm text-mt-secondary"><span class="font-mono font-black text-mt-accent mt-0.5">→</span><span>{use}</span></li>
          ))}
        </ul>
      </div>
    </section>
  )}

  {/* Quick specs for products */}
  {type === 'product' && product!.fraction && (
    <section class="border-b border-mt-divider">
      <div class="max-w-[1440px] mx-auto grid grid-cols-2 md:grid-cols-4">
        {[{ v:'1400', l:'КГ/М³' },{ v:'F300', l:'МОРОЗ.' },{ v:'≤15%', l:'ЛЕЩАД.' },{ v:'М1200', l:'МІЦНІСТЬ' }].map((s)=>(
          <div class="px-6 py-8 border-r border-b border-mt-divider last:border-r-0 text-center"><div class="font-mono font-black text-2xl md:text-3xl text-mt-accent leading-none mb-2">{s.v}</div><div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest">{s.l}</div></div>
        ))}
      </div>
    </section>
  )}

  {/* Related for products */}
  {related.length > 0 && (
    <section class="py-16 md:py-24 border-b border-mt-divider">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12">
        <h2 class="font-display font-black text-2xl md:text-4xl uppercase tracking-tight mb-10">Інші фракції</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-mt-divider border border-mt-divider">
          {related.map((p) => (
            <a href={`/uk/materialy/${p.slug}/`} class="bg-mt-bg-1 p-6 md:p-8 hover:bg-mt-bg-2 transition-colors block">
              <div class="font-display font-black text-lg uppercase tracking-tight mb-2">{p.name}</div>
              <div class="font-mono font-black text-2xl text-mt-accent">{p.price} ₴ <span class="text-sm text-mt-tertiary">/ {p.unit}</span></div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <FAQ items={faq} title="Запитання" />

  <CTABanner
    title={`${name} з доставкою`}
    subtitle={`Від ${priceFrom} ₴/${unit}. Доставка самоскидом ACTROS.`}
    buttonText="Замовити →"
    buttonHref="/uk/kontakty/"
  />
</PageLayout>
