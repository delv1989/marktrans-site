---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ProductCard from '../../../components/ProductCard.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { shchebenProducts, faqShcheben } from '../../../data/products';

const title = 'Щебінь з доставкою по Києву — від 170 ₴/тонна · MARKTRANS';
const description = 'Гранітний щебінь усіх фракцій: 5-10, 5-20, 20-40, 40-70 мм. Ціна від 170 ₴/тонна. Доставка самоскидом ACTROS у день замовлення. Київ і Київська область.';
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: 'Головна', href: '/uk/' },
    { label: 'Матеріали', href: '/uk/' },
    { label: 'Щебінь' }
  ]} />

  <!-- Page header with direct-answer for GEO -->
  <section class="py-16 md:py-24 lg:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h1
        class="font-display font-black uppercase mb-4"
        style="font-size: clamp(56px, 12vw, 144px); line-height: 0.85; letter-spacing: -0.04em;"
      >
        ЩЕБІНЬ
      </h1>
      <div class="font-mono text-xs text-mt-tertiary uppercase tracking-widest mb-8">
        {shchebenProducts.length} позицій · від 170 ₴/тонна · Доставка по Києву та області
      </div>
      <p class="text-base md:text-lg text-mt-secondary max-w-[800px] leading-relaxed">
        Щебінь — сипучий будівельний матеріал з гранітних порід. MARKTRANS постачає гранітний щебінь
        усіх стандартних фракцій з власного кар'єру. Ціна від 170 ₴/тонна. Мінімальна партія 1 тонна.
        Доставка самоскидом ACTROS в день замовлення при оформленні до 16:00.
      </p>
    </div>
  </section>

  <!-- Product grid -->
  <section class="border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24">
      <SectionHeader
        eyebrow="КАТАЛОГ"
        titleLine1="ФРАКЦІЇ"
        titleAccent="ЩЕБЕНЮ"
        meta={[`${shchebenProducts.length} ПОЗИЦІЙ`, 'ОНОВЛЕНО СЬОГОДНІ']}
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-mt-divider">
        {shchebenProducts.map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
    </div>
  </section>

  <!-- Technical info — GEO content -->
  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24">
        <!-- Fraction table -->
        <div>
          <h2 class="font-display font-black text-2xl md:text-3xl uppercase tracking-tight mb-8">
            Яка фракція для чого
          </h2>
          <div class="border border-mt-divider divide-y divide-mt-divider">
            {[
              ['0-5 мм', 'Підсипка, дренаж, вирівнювання'],
              ['5-10 мм', 'Бетон М200-М400, тротуарна плитка'],
              ['5-20 мм', 'Бетон, фундамент плитний'],
              ['20-40 мм', 'Фундамент стрічковий, дорожнє покриття'],
              ['40-70 мм', 'Дорожнє будівництво, залізниця'],
              ['70-120 мм', 'Великі підпірні конструкції'],
            ].map(([fraction, use]) => (
              <div class="flex">
                <div class="w-1/3 px-4 py-3 font-mono text-sm font-bold text-mt-accent border-r border-mt-divider">{fraction}</div>
                <div class="w-2/3 px-4 py-3 text-sm text-mt-secondary">{use}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- How to choose -->
        <div>
          <h2 class="font-display font-black text-2xl md:text-3xl uppercase tracking-tight mb-8">
            Як обрати правильно
          </h2>
          <ul class="space-y-4">
            {[
              'Для стрічкового фундаменту — 20-40 мм',
              'Для плитного фундаменту — 5-20 мм',
              'Для бетону М200-М400 — 5-20 мм',
              'Для дренажу — 20-40 мм',
              'Для тротуарної плитки — 5-10 мм',
            ].map((text) => (
              <li class="flex items-start gap-3 text-sm text-mt-secondary">
                <span class="font-mono font-black text-mt-accent mt-0.5">→</span>
                <span>{text}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <FAQ items={faqShcheben} />

  <CTABanner
    title="Не знаєте яку фракцію?"
    subtitle="Подзвоніть — розкажемо та порахуємо під ваш об'єкт."
    buttonText="Подзвонити →"
    buttonHref="tel:+380504204229"
  />
</PageLayout>
