---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';

const entries = await getCollection('materials', ({ data }) => data.locale === 'uk');
const sorted = entries.sort((a, b) => a.data.title.localeCompare(b.data.title, 'uk'));

const title = 'Будівельні матеріали з доставкою по Києву — MARKTRANS';
const description = 'Щебінь, пісок, асфальт, бетон, ЩПС, ґрунт, сіль — від 100 ₴/тонна. Доставка самоскидом ACTROS у день замовлення.';

const faq = [
  { question: 'Яка мінімальна партія?', answer: 'Стандартний мінімум — 1 повна машина (20 тонн ACTROS). Менші об\u2019єми від 5 тонн — за домовленістю.' },
  { question: 'Чи доставляєте по вихідних?', answer: 'Так, працюємо 7 днів на тиждень, диспетчер доступний 24/7.' },
  { question: 'Які форми оплати?', answer: 'Готівка, безготівковий розрахунок (рахунок для ТОВ/ФОП), відстрочка до 14 днів постійним клієнтам.' },
  { question: 'Чи є сертифікати якості?', answer: 'Так, на кожну партію надаємо паспорт якості та сертифікат відповідності ДСТУ.' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: 'Головна', href: '/uk/' },
    { label: 'Матеріали' }
  ]} />

  <section class="py-16 md:py-24 lg:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="block w-8 h-0.5 bg-mt-accent"></span>
        <span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Каталог</span>
      </div>
      <h1 class="font-display font-black uppercase mb-6" style="font-size: clamp(56px, 12vw, 144px); line-height: 0.85; letter-spacing: -0.04em;">
        СИПУЧІ<br/><span class="text-mt-accent">МАТЕРІАЛИ</span>
      </h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[800px] leading-relaxed">
        MARKTRANS постачає весь спектр сипучих будматеріалів з власних та партнерських кар'єрів.
        Гранітний щебінь усіх фракцій, пісок, ЩПС, асфальтобетонні суміші, ґрунт, технічна сіль.
        Доставка ACTROS у день замовлення по Києву та області в радіусі 200 км.
      </p>
    </div>
  </section>

  <section class="border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24">
      <SectionHeader
        eyebrow="КАТАЛОГ"
        titleLine1="КАТЕГОРІЇ"
        titleAccent="МАТЕРІАЛІВ"
        meta={[`${sorted.length} ПОЗИЦІЙ`, 'ВІД 100 ₴/ТОННА']}
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-mt-divider">
        {sorted.map((entry) => (
          <a
            href={`/uk/materialy/${entry.data.slug}/`}
            class="group block bg-mt-bg-1 border-r border-b border-mt-divider transition-colors hover:bg-mt-bg-2 hover:border-mt-accent"
          >
            {entry.data.image && (
              <div class="h-48 md:h-56 overflow-hidden">
                <img src={entry.data.image} alt={entry.data.title} loading="lazy" class="w-full h-full object-cover brightness-75 grayscale-[30%] transition-transform duration-700 group-hover:scale-[1.06] group-hover:brightness-90 group-hover:grayscale-0" />
              </div>
            )}
            <div class="p-6 md:p-8">
              <h3 class="font-display font-black text-lg md:text-xl uppercase tracking-tight mb-2">{entry.data.title}</h3>
              {entry.data.priceFrom && (
                <div class="flex items-baseline gap-2">
                  <span class="font-mono font-black text-2xl text-mt-accent">{entry.data.priceFrom} ₴</span>
                  <span class="font-mono text-[11px] text-mt-tertiary uppercase tracking-widest">/ тонна</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faq} />

  <CTABanner
    title="Потрібен матеріал?"
    subtitle="Подзвоніть або напишіть в Telegram — розрахуємо вартість за 5 хвилин."
    buttonText="Замовити доставку →"
    buttonHref="/uk/kontakty/"
  />
</PageLayout>
