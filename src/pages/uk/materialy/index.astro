---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ProductCard from '../../../components/ProductCard.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { shchebenProducts, faqShcheben } from '../../../data/products';
import { materials } from '../../../data/content';

const title = 'Будівельні матеріали з доставкою по Києву — MARKTRANS';
const description = 'Щебінь, пісок, асфальт, бетон, ЩПС, ґрунт, сіль — від 150 ₴/тонна. Доставка самоскидом ACTROS у день замовлення. Київ і Київська область.';
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: 'Головна', href: '/uk/' },
    { label: 'Матеріали' }
  ]} />

  <section class="py-16 md:py-24 lg:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="block w-8 h-0.5 bg-mt-accent"></span>
        <span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Каталог</span>
      </div>
      <h1
        class="font-display font-black uppercase mb-6"
        style="font-size: clamp(56px, 12vw, 144px); line-height: 0.85; letter-spacing: -0.04em;"
      >
        БУДІВЕЛЬНІ<br/><span class="text-mt-accent">МАТЕРІАЛИ</span>
      </h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[800px] leading-relaxed">
        MARKTRANS постачає сипучі будівельні матеріали власним автопарком ACTROS.
        Щебінь усіх фракцій, пісок, асфальтобетонні суміші, бетон, ЩПС, ґрунт, технічна сіль.
        Ціна від 150 ₴/тонна. Доставка у день замовлення при оформленні до 16:00.
      </p>
    </div>
  </section>

  <!-- All 9 categories -->
  <section class="border-b border-mt-divider" id="categories">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24">
      <SectionHeader
        eyebrow="КАТАЛОГ"
        titleLine1="КАТЕГОРІЇ"
        titleAccent="МАТЕРІАЛІВ"
        meta={[`${materials.length} КАТЕГОРІЙ`, 'ВІД 150 ₴/ТОННА']}
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-mt-divider">
        {materials.map((m) => (
          <a
            href={m.href}
            class="group block aspect-[4/3] relative overflow-hidden bg-mt-bg-1 border-r border-b border-mt-divider"
          >
            <img src={m.image} alt={m.alt} loading="lazy" class="absolute inset-0 w-full h-full object-cover brightness-75 contrast-[1.15] grayscale-[35%] transition-transform duration-700 group-hover:scale-[1.06] group-hover:brightness-90 group-hover:grayscale-0" />
            <div class="absolute inset-0 flex flex-col justify-end p-6 md:p-8" style="background: linear-gradient(180deg, transparent 0%, rgba(15,15,15,0.35) 45%, rgba(15,15,15,0.96) 100%);">
              <div class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.15em] mb-3">{m.num}</div>
              <h3 class="font-display font-black text-xl md:text-2xl uppercase tracking-tight mb-4" style="text-shadow: 0 2px 16px rgba(0,0,0,0.5);">
                {m.title.split('\n').map((line: string, i: number) => <>{i > 0 && <br/>}{line}</>)}
              </h3>
              <div class="flex items-center gap-2 font-display font-black text-[13px] text-mt-accent uppercase tracking-widest opacity-85 group-hover:opacity-100 group-hover:gap-3.5 transition-all">
                Детальніше →
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Shcheben preview — most popular -->
  <section class="border-b border-mt-divider" id="shcheben">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24">
      <SectionHeader
        eyebrow="НАЙПОПУЛЯРНІШЕ"
        titleLine1="ФРАКЦІЇ"
        titleAccent="ЩЕБЕНЮ"
        meta={[`${shchebenProducts.length} ПОЗИЦІЙ`, 'ВІД 170 ₴/ТОННА']}
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-mt-divider">
        {shchebenProducts.slice(0, 6).map((product) => (
          <ProductCard product={product} />
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/uk/materialy/shcheben/" class="inline-flex items-center gap-3 px-8 py-4 border-2 border-mt-divider font-display font-black text-sm uppercase tracking-wider hover:border-mt-accent hover:text-mt-accent transition-all rounded-xs">
          Всі фракції щебеню →
        </a>
      </div>
    </div>
  </section>

  <FAQ items={faqShcheben} />

  <CTABanner
    title="Потрібен матеріал?"
    subtitle="Подзвоніть або напишіть в Telegram — розрахуємо вартість за 5 хвилин."
    buttonText="Замовити доставку →"
    buttonHref="/uk/kontakty/"
  />
</PageLayout>
