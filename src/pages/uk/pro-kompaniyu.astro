---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';

const title = 'Про компанію MARKTRANS — доставка будматеріалів з 2015 року';
const description = 'MARKTRANS — сімейна компанія з Києва. Власний автопарк 5 самоскидів ACTROS, штатні водії, доставка щебеню, піску, асфальту по Києву та області з 2015 року.';

const timeline = [
  { year: '2015', title: 'Перший ACTROS', text: 'Володимир Ткаченко купує перший самоскид і починає возити щебінь по Київщині.' },
  { year: '2017', title: 'Розширення', text: 'Автопарк зростає до 3 машин. Додаємо послугу оренди спецтехніки.' },
  { year: '2019', title: 'Перший держтендер', text: 'Перемагаємо в тендері Укравтодору на поставку матеріалів.' },
  { year: '2021', title: 'Автопарк 5 машин', text: 'Додаємо ще 2 ACTROS. Залучаємо постійних диспетчерів 24/7.' },
  { year: '2023', title: 'Цифрова трансформація', text: 'Запускаємо Telegram-бот для замовлень і внутрішню CRM-систему.' },
  { year: '2026', title: 'Нова платформа', text: 'Повний редизайн сайту, перехід на сучасний стек, AI-оптимізація для пошуку.' },
];

const stats = [
  { value: '2015', label: 'Рік заснування' },
  { value: '5', label: 'Самоскидів ACTROS' },
  { value: '12 000+', label: 'Виконаних рейсів' },
  { value: '200K', label: 'Тонн перевезено' },
  { value: '38', label: 'Постійних клієнтів' },
  { value: '24/7', label: 'Диспетчер' },
];

const values = [
  { title: 'Прозорість', text: 'Ціни без прихованих комісій. Оплата за результат — після приймання матеріалу.' },
  { title: 'Пунктуальність', text: 'Вчасно — це стандарт, не бонус. Доставка у день замовлення по Києву.' },
  { title: 'Якість матеріалу', text: 'Прямо з сертифікованих кар\'єрів. ДСТУ-відповідність по кожній фракції.' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: 'Головна', href: '/uk/' },
    { label: 'Про компанію' }
  ]} />

  <!-- Hero -->
  <section class="py-16 md:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="block w-8 h-0.5 bg-mt-accent"></span>
        <span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Established 2015</span>
      </div>
      <h1
        class="font-display font-black uppercase mb-8"
        style="font-size: clamp(64px, 12vw, 160px); line-height: 0.85; letter-spacing: -0.04em;"
      >
        MARKTRANS
      </h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[720px] leading-relaxed">
        Сімейна компанія з Києва. Власний автопарк, власний досвід, власна відповідальність за кожен рейс.
        Доставляємо сипучі будівельні матеріали — щебінь, пісок, асфальт, бетон — по Києву та Київській області з 2015 року.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6">
      {stats.map((stat) => (
        <div class="px-6 py-10 md:py-12 border-r border-b border-mt-divider last:border-r-0">
          <div class="font-mono font-black text-3xl md:text-4xl text-mt-accent leading-none mb-2">{stat.value}</div>
          <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest">{stat.label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Timeline -->
  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight mb-12">Наша історія</h2>
      <div class="relative pl-8 md:pl-12 border-l-2 border-mt-accent space-y-10">
        {timeline.map((item) => (
          <div class="relative">
            <div class="absolute -left-[calc(2rem+5px)] md:-left-[calc(3rem+5px)] top-1 w-2.5 h-2.5 bg-mt-accent rounded-full"></div>
            <div class="font-mono font-black text-2xl md:text-3xl text-mt-accent leading-none mb-2">{item.year}</div>
            <div class="font-display font-black text-lg uppercase tracking-tight mb-1">{item.title}</div>
            <p class="text-sm text-mt-secondary leading-relaxed max-w-[640px]">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Direct answer — GEO -->
  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight mb-8">Чим ми відрізняємося</h2>
      <p class="text-base md:text-lg text-mt-secondary max-w-[800px] leading-relaxed">
        MARKTRANS — не посередник і не агрегатор. Ми володіємо власним автопарком з 5 самоскидів Mercedes ACTROS,
        маємо штатних водіїв-професіоналів з середнім стажем 12 років, і беремо на себе відповідальність за кожен рейс
        від кар'єру до вашого об'єкта. Це означає: ніяких перекидань між перевізниками, однозначні терміни, чіткі ціни
        без прихованих націнок.
      </p>
    </div>
  </section>

  <!-- Values -->
  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-mt-divider border border-mt-divider">
        {values.map((v) => (
          <div class="bg-mt-bg p-8 md:p-10">
            <h3 class="font-display font-black text-xl uppercase tracking-tight mb-4 text-mt-accent">{v.title}</h3>
            <p class="text-sm text-mt-secondary leading-relaxed">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    title="Потрібен надійний постачальник?"
    subtitle="Працюємо по всій Київській області. Чесні ціни, гарантований об'єм."
    buttonText="Замовити рейс →"
    buttonHref="/uk/kontakty/"
  />
</PageLayout>
