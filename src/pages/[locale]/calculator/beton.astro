---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import OrderForm from '../../../components/OrderForm.astro';
import CalculatorD from '../../../components/CalculatorD.astro';

export async function getStaticPaths() {
  return [{ params: { locale: 'uk' } }, { params: { locale: 'ru' } }];
}

const { locale } = Astro.params as { locale: 'uk' | 'ru' };
const isUk = locale === 'uk';

const title = isUk
  ? 'Калькулятор бетону для фундаменту онлайн — MARKTRANS'
  : 'Калькулятор бетона для фундамента онлайн — MARKTRANS';
const description = isUk
  ? 'Безкоштовний онлайн-калькулятор бетону. Розрахуйте обʼєм та марку для стрічкового, плитного або пальового фундаменту.'
  : 'Бесплатный онлайн-калькулятор бетона. Рассчитайте объём и марку для ленточного, плитного или свайного фундамента.';
---
<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: isUk ? 'Головна' : 'Главная', href: `/${locale}/` },
    { label: isUk ? 'Калькулятор' : 'Калькулятор', href: `/${locale}/calculator/` },
    { label: isUk ? 'Бетон' : 'Бетон' },
  ]} />

  <section class="py-12 md:py-20 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h1 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight leading-none mb-4">
        {isUk ? 'Калькулятор' : 'Калькулятор'} <span class="text-mt-accent">{isUk ? 'бетону' : 'бетона'}</span>
      </h1>
      <p class="text-base text-mt-secondary max-w-[700px] leading-relaxed mb-8">
        {isUk
          ? 'Розрахуйте скільки кубів бетону потрібно для фундаменту і якої марки. Підходить для стрічкового, плитного і пальово-ростверкового.'
          : 'Рассчитайте сколько кубов бетона нужно для фундамента и какой марки. Подходит для ленточного, плитного и свайно-ростверкового.'}
      </p>
      <CalculatorD locale={locale} />
    </div>
  </section>

  <section id="order-section" class="py-12 md:py-20 border-b border-mt-divider">
    <div class="max-w-[880px] mx-auto px-6 md:px-12 flex justify-center">
      <OrderForm locale={locale} />
    </div>
  </section>
</PageLayout>
