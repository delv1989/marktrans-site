---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import OrderForm from '../../../components/OrderForm.astro';
import CalculatorB from '../../../components/CalculatorB.astro';
import CalculatorC from '../../../components/CalculatorC.astro';
import CalculatorD from '../../../components/CalculatorD.astro';

export async function getStaticPaths() {
  return [{ params: { locale: 'uk' } }, { params: { locale: 'ru' } }];
}

const { locale } = Astro.params as { locale: 'uk' | 'ru' };
const isUk = locale === 'uk';

const title = isUk ? 'Калькулятор матеріалів — MARKTRANS' : 'Калькулятор материалов — MARKTRANS';
const description = isUk
  ? 'Безкоштовні калькулятори: обʼєм сипучих матеріалів, вивіз сміття, бетон для фундаменту. Доставка по Києву та області.'
  : 'Бесплатные калькуляторы: объём сыпучих материалов, вывоз мусора, бетон для фундамента. Доставка по Киеву и области.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: isUk ? 'Калькулятор матеріалів MARKTRANS' : 'Калькулятор материалов MARKTRANS',
  description,
  applicationCategory: 'UtilityApplication',
  operatingSystem: 'Any',
  url: new URL(`/${locale}/calculator/`, Astro.site).href,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'UAH' },
  inLanguage: isUk ? 'uk-UA' : 'ru-UA',
};
---
<PageLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <Breadcrumbs items={[
    { label: isUk ? 'Головна' : 'Главная', href: `/${locale}/` },
    { label: isUk ? 'Калькулятор' : 'Калькулятор' },
  ]} />

  <section class="py-12 md:py-20 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h1 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight leading-none mb-4">
        {isUk ? 'Калькулятор' : 'Калькулятор'} <span class="text-mt-accent">{isUk ? 'матеріалів' : 'материалов'}</span>
      </h1>
      <p class="text-base text-mt-secondary max-w-[700px] leading-relaxed mb-8">{description}</p>

      <!-- Tabs -->
      <div class="flex flex-wrap gap-0.5 border-b-2 border-mt-divider mb-8" role="tablist">
        <button class="calc-hub-tab active px-5 py-3 text-xs font-bold uppercase tracking-widest text-mt-secondary border-b-2 border-transparent -mb-[2px] hover:text-mt-text transition-colors" role="tab" data-tab="b">
          {isUk ? '📐 Обʼєм по площі' : '📐 Объём по площади'}
        </button>
        <button class="calc-hub-tab px-5 py-3 text-xs font-bold uppercase tracking-widest text-mt-secondary border-b-2 border-transparent -mb-[2px] hover:text-mt-text transition-colors" role="tab" data-tab="c">
          {isUk ? '🚛 Вивіз сміття' : '🚛 Вывоз мусора'}
        </button>
        <button class="calc-hub-tab px-5 py-3 text-xs font-bold uppercase tracking-widest text-mt-secondary border-b-2 border-transparent -mb-[2px] hover:text-mt-text transition-colors" role="tab" data-tab="d">
          {isUk ? '🏗 Бетон' : '🏗 Бетон'}
        </button>
      </div>

      <div data-panel="b"><CalculatorB locale={locale} /></div>
      <div data-panel="c" hidden><CalculatorC locale={locale} /></div>
      <div data-panel="d" hidden><CalculatorD locale={locale} /></div>
    </div>
  </section>

  <section id="order-section" class="py-12 md:py-20 border-b border-mt-divider">
    <div class="max-w-[880px] mx-auto px-6 md:px-12 flex justify-center">
      <OrderForm locale={locale} />
    </div>
  </section>
</PageLayout>

<script>
  const tabs = document.querySelectorAll('.calc-hub-tab');
  const panels = document.querySelectorAll('[data-panel]');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const t = tab.getAttribute('data-tab');
      tabs.forEach(x => {
        x.classList.toggle('active', x === tab);
        if (x === tab) {
          x.style.color = 'var(--color-mt-accent)';
          x.style.borderBottomColor = 'var(--color-mt-accent)';
        } else {
          x.style.color = '';
          x.style.borderBottomColor = 'transparent';
        }
      });
      panels.forEach(p => { p.hidden = p.getAttribute('data-panel') !== t; });
    });
  });

  // Init active tab style
  const first = document.querySelector('.calc-hub-tab.active') as HTMLElement;
  if (first) { first.style.color = 'var(--color-mt-accent)'; first.style.borderBottomColor = 'var(--color-mt-accent)'; }

  // Hash-based tab switch
  function applyHash() {
    const h = window.location.hash.slice(1);
    if (['b', 'c', 'd'].includes(h)) {
      const tab = document.querySelector(`.calc-hub-tab[data-tab="${h}"]`) as HTMLElement;
      if (tab) tab.click();
    }
  }
  window.addEventListener('hashchange', applyHash);
  applyHash();
</script>
