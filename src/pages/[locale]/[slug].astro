---
import { getCollection, render } from 'astro:content';
import { getHreflangAlternatesByConcept } from '../../lib/hreflang';
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';
import OrderForm from '../../components/OrderForm.astro';

export async function getStaticPaths() {
  const entries = await getCollection('info');
  return entries.map((entry) => ({
    params: { locale: entry.data.locale, slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const locale = entry.data.locale;
const isUk = locale === 'uk';
const alternates = await getHreflangAlternatesByConcept(entry.data.conceptId, 'info');
const ogPath = `/og/${locale}/${entry.data.slug}.jpg`;
const isKontakty = entry.data.slug === 'kontakty' || entry.data.slug === 'kontakti';
---

<PageLayout title={entry.data.metaTitle} description={entry.data.metaDescription} alternateUk={alternates.uk} alternateRu={alternates.ru} ogImage={ogPath} conceptId={entry.data.conceptId} collection="info">
  <Breadcrumbs items={[
    { label: isUk ? 'Головна' : 'Главная', href: `/${locale}/` },
    { label: entry.data.title },
  ]} />

  <article class="py-12 md:py-20">
    <div class="max-w-[880px] mx-auto px-6 md:px-12">
      <h1 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight leading-none mb-10">
        {entry.data.h1}
      </h1>

      <div class="prose prose-invert prose-lg max-w-none [&_h2]:font-display [&_h2]:font-black [&_h2]:uppercase [&_h2]:tracking-tight [&_h2]:text-2xl [&_h2]:mt-12 [&_h2]:mb-6 [&_h3]:font-display [&_h3]:font-bold [&_h3]:uppercase [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-4 [&_strong]:text-mt-accent [&_p]:text-mt-secondary [&_p]:leading-relaxed [&_li]:text-mt-secondary [&_a]:text-mt-accent [&_a:hover]:text-mt-accent-hover [&_table]:border-mt-divider [&_th]:border-mt-divider [&_td]:border-mt-divider [&_blockquote]:border-l-mt-accent [&_blockquote]:text-mt-secondary [&_hr]:border-mt-divider">
        <Content />
      </div>
    </div>
  </article>

  {isKontakty && (
    <section id="order-section" class="py-12 md:py-20 border-b border-mt-divider">
      <div class="max-w-[880px] mx-auto px-6 md:px-12 flex justify-center">
        <OrderForm locale={locale as 'uk' | 'ru'} />
      </div>
    </section>
  )}

  <CTABanner
    title={isUk ? 'Потрібна допомога?' : 'Нужна помощь?'}
    subtitle={isUk ? 'Подзвоніть — відповімо на всі запитання.' : 'Позвоните — ответим на все вопросы.'}
    buttonText={isUk ? 'Подзвонити →' : 'Позвонить →'}
    buttonHref="tel:+380504204229"
  />
</PageLayout>
