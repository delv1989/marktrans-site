---
import { getCollection, render } from 'astro:content';
import { getHreflangAlternatesByConcept } from '../../../lib/hreflang';
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CTABanner from '../../../components/CTABanner.astro';
import CalculatorC from '../../../components/CalculatorC.astro';
import OrderForm from '../../../components/OrderForm.astro';

export async function getStaticPaths() {
  const entries = await getCollection('works');
  return entries.map((entry) => ({
    params: { locale: entry.data.locale, slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const locale = entry.data.locale;
const isUk = locale === 'uk';
const alternates = await getHreflangAlternatesByConcept(entry.data.conceptId, 'works');
const ogPath = `/og/${locale}/roboty/${entry.data.slug}.jpg`;
const isWasteCalc = entry.data.slug.includes('vyviz') || entry.data.slug.includes('vyvoz');

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: isUk ? 'Будівельні роботи' : 'Строительные работы',
  name: entry.data.title,
  description: entry.data.metaDescription,
  image: entry.data.image ? new URL(entry.data.image, Astro.site).toString() : undefined,
  provider: {
    '@type': 'LocalBusiness',
    '@id': new URL('/#business', Astro.site).toString(),
    name: 'MARKTRANS',
    telephone: '+380504204229',
  },
  areaServed: {
    '@type': 'GeoCircle',
    geoMidpoint: { '@type': 'GeoCoordinates', latitude: 50.4501, longitude: 30.5234 },
    geoRadius: '200000',
  },
  ...(entry.data.priceFrom ? {
    offers: {
      '@type': 'Offer',
      priceCurrency: 'UAH',
      price: String(entry.data.priceFrom),
    },
  } : {}),
  inLanguage: isUk ? 'uk-UA' : 'ru-UA',
};
---

<PageLayout title={entry.data.metaTitle} description={entry.data.metaDescription} alternateUk={alternates.uk} alternateRu={alternates.ru} ogImage={ogPath} conceptId={entry.data.conceptId} collection="works">
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  <Breadcrumbs items={[
    { label: isUk ? 'Головна' : 'Главная', href: `/${locale}/` },
    { label: isUk ? 'Роботи' : 'Работы', href: `/${locale}/roboty/` },
    { label: entry.data.title },
  ]} />

  <article class="py-12 md:py-20 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        {entry.data.image && (
          <div class="aspect-[4/3] rounded-sm overflow-hidden bg-mt-bg-1 border border-mt-divider">
            <img src={entry.data.image} alt={entry.data.title} class="w-full h-full object-cover" loading="eager" fetchpriority="high" />
          </div>
        )}
        <div class="flex flex-col justify-center">
          <h1 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight leading-none mb-6">{entry.data.h1}</h1>
          {entry.data.priceFrom && (
            <div class="flex items-baseline gap-4 mb-8 pb-8 border-b border-mt-divider">
              <span class="font-mono font-black text-5xl md:text-6xl text-mt-accent leading-none tracking-tight">{entry.data.priceFrom.toLocaleString('uk-UA')} ₴</span>
              <span class="font-mono text-sm text-mt-tertiary uppercase tracking-widest">/ {isUk ? 'тонна' : 'тонна'}</span>
            </div>
          )}
          <div class="flex flex-col sm:flex-row gap-4">
            <a href={locale === 'ru' ? '/ru/kontakti/' : `/${locale}/kontakty/`} class="btn-primary justify-center">{isUk ? 'Замовити доставку →' : 'Заказать доставку →'}</a>
            <a href="tel:+380504204229" class="btn-secondary justify-center">{isUk ? 'Подзвонити' : 'Позвонить'}</a>
          </div>
        </div>
      </div>
    </div>
  </article>

  <section class="py-12 md:py-20">
    <div class="max-w-[880px] mx-auto px-6 md:px-12">
      <div class="prose prose-invert prose-lg max-w-none [&_h2]:font-display [&_h2]:font-black [&_h2]:uppercase [&_h2]:tracking-tight [&_h2]:text-2xl [&_h2]:mt-12 [&_h2]:mb-6 [&_h3]:font-display [&_h3]:font-bold [&_h3]:uppercase [&_h3]:text-xl [&_h3]:mt-8 [&_h3]:mb-4 [&_strong]:text-mt-accent [&_p]:text-mt-secondary [&_p]:leading-relaxed [&_li]:text-mt-secondary [&_a]:text-mt-accent [&_a:hover]:text-mt-accent-hover [&_table]:border-mt-divider [&_th]:border-mt-divider [&_td]:border-mt-divider [&_blockquote]:border-l-mt-accent [&_blockquote]:text-mt-secondary [&_code]:text-mt-accent [&_hr]:border-mt-divider">
        <Content />
      </div>
    </div>
  </section>

  {entry.data.gallery && entry.data.gallery.length > 1 && (
    <section class="py-12 border-b border-mt-divider">
      <div class="max-w-[1440px] mx-auto px-6 md:px-12">
        <h2 class="font-display font-black text-2xl uppercase tracking-tight mb-8">{isUk ? 'Галерея' : 'Галерея'}</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-2">
          {entry.data.gallery.slice(1).map((img: string) => (
            <img src={img} alt="" loading="lazy" class="w-full aspect-square object-cover rounded-sm border border-mt-divider" />
          ))}
        </div>
      </div>
    </section>
  )}

  {isWasteCalc && (
    <section class="py-12 md:py-20 border-b border-mt-divider">
      <div class="max-w-[880px] mx-auto px-6 md:px-12 flex justify-center">
        <CalculatorC locale={locale as 'uk' | 'ru'} />
      </div>
    </section>
  )}

  {isWasteCalc && (
    <section id="order-section" class="py-12 md:py-20 border-b border-mt-divider">
      <div class="max-w-[880px] mx-auto px-6 md:px-12 flex justify-center">
        <OrderForm locale={locale as 'uk' | 'ru'} />
      </div>
    </section>
  )}

  <CTABanner
    title={isUk ? `${entry.data.title} з доставкою` : `${entry.data.title} с доставкой`}
    subtitle={entry.data.priceFrom ? `${isUk ? 'Від' : 'От'} ${entry.data.priceFrom.toLocaleString('uk-UA')} ₴. ${isUk ? 'Доставка самоскидом ACTROS.' : 'Доставка самосвалом ACTROS.'}` : undefined}
    buttonText={isUk ? 'Замовити →' : 'Заказать →'}
    buttonHref={locale === 'ru' ? '/ru/kontakti/' : `/${locale}/kontakty/`}
  />
</PageLayout>
