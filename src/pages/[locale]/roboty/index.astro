---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';

export async function getStaticPaths() {
  return [{ params: { locale: 'uk' } }, { params: { locale: 'ru' } }];
}

const { locale } = Astro.params as { locale: 'uk' | 'ru' };
const isUk = locale === 'uk';
const entries = await getCollection('works', ({ data }) => data.locale === locale);
const sorted = entries.sort((a, b) => a.data.title.localeCompare(b.data.title, locale));

const title = isUk ? 'Будівельні роботи Київ — MARKTRANS' : 'Строительные работы Киев — MARKTRANS';
const description = isUk ? 'Повний цикл будівельних робіт власною технікою.' : 'Полный цикл строительных работ собственной техникой.';

const faq = isUk ? [
  { question: 'Чи працюєте з юридичними особами?', answer: 'Так, підписуємо договір підряду з ТОВ та ФОП.' },
  { question: 'Який мінімальний обсяг?', answer: 'Асфальтування — від 100 м². Земляні роботи — від 1 зміни.' },
  { question: 'Чи надаєте кошторис?', answer: 'Так, безкоштовний попередній кошторис після огляду об\u2019єкта.' },
] : [
  { question: 'Работаете с юрлицами?', answer: 'Да, подписываем договор подряда с ООО и ФЛП.' },
  { question: 'Какой минимальный объём?', answer: 'Асфальтирование — от 100 м². Земляные работы — от 1 смены.' },
  { question: 'Предоставляете смету?', answer: 'Да, бесплатная предварительная смета после осмотра объекта.' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: isUk ? 'Головна' : 'Главная', href: `/${locale}/` }, { label: isUk ? 'Будівельні роботи' : 'Строительные работы' }]} />

  <section class="py-16 md:py-24 lg:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6"><span class="block w-8 h-0.5 bg-mt-accent"></span><span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— {isUk ? 'Послуги' : 'Услуги'}</span></div>
      <h1 class="font-display font-black uppercase mb-6" style="font-size: clamp(48px, 10vw, 120px); line-height: 0.88; letter-spacing: -0.03em;">{isUk ? 'БУДІВЕЛЬНІ' : 'СТРОИТЕЛЬНЫЕ'}<br/><span class="text-mt-accent">{isUk ? 'РОБОТИ' : 'РАБОТЫ'}</span></h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[720px] leading-relaxed">{description}</p>
    </div>
  </section>

  <section class="border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24">
      <SectionHeader eyebrow={isUk ? 'ПОСЛУГИ' : 'УСЛУГИ'} titleLine1={isUk ? 'БУДІВЕЛЬНІ' : 'СТРОИТЕЛЬНЫЕ'} titleAccent={isUk ? 'РОБОТИ' : 'РАБОТЫ'} meta={[`${sorted.length} ${isUk ? 'НАПРЯМКІВ' : 'НАПРАВЛЕНИЙ'}`]} />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-mt-divider">
        {sorted.map((entry) => (
          <a href={`/${locale}/roboty/${entry.data.slug}/`} class="group block bg-mt-bg-1 border-r border-b border-mt-divider transition-colors hover:bg-mt-bg-2 hover:border-mt-accent">
            {entry.data.image && (<div class="h-48 md:h-56 overflow-hidden"><img src={entry.data.image} alt={entry.data.title} loading="lazy" class="w-full h-full object-cover brightness-75 grayscale-[30%] transition-transform duration-700 group-hover:scale-[1.06]" /></div>)}
            <div class="p-6 md:p-8">
              <h3 class="font-display font-black text-lg uppercase tracking-tight mb-2">{entry.data.title}</h3>
              {entry.data.priceFrom && (<span class="font-mono font-black text-2xl text-mt-accent">{entry.data.priceFrom} ₴</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faq} title={isUk ? 'Запитання про роботи' : 'Вопросы о работах'} />
  <CTABanner title={isUk ? 'Потрібні будівельні роботи?' : 'Нужны строительные работы?'} subtitle={isUk ? 'Безкоштовний кошторис після огляду.' : 'Бесплатная смета после осмотра.'} buttonText={isUk ? 'Замовити огляд →' : 'Заказать осмотр →'} buttonHref={`/${locale}/kontakty/`} />
</PageLayout>
