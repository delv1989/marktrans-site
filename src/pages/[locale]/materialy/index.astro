---
import { getCollection } from 'astro:content';
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';

export async function getStaticPaths() {
  return [{ params: { locale: 'uk' } }, { params: { locale: 'ru' } }];
}

const { locale } = Astro.params as { locale: 'uk' | 'ru' };
const isUk = locale === 'uk';
const entries = await getCollection('materials', ({ data }) => data.locale === locale);
const sorted = entries.sort((a, b) => a.data.title.localeCompare(b.data.title, locale));

const title = isUk ? 'Будівельні матеріали з доставкою по Києву — MARKTRANS' : 'Строительные материалы с доставкой по Киеву — MARKTRANS';
const description = isUk ? 'Щебінь, пісок, асфальт, бетон, ЩПС — від 100 ₴/тонна. Доставка самоскидом ACTROS.' : 'Щебень, песок, асфальт, бетон, ЩПС — от 100 ₴/тонна. Доставка самосвалом ACTROS.';

const faq = isUk ? [
  { question: 'Яка мінімальна партія?', answer: 'Стандартний мінімум — 1 повна машина (20 тонн ACTROS). Менші об\u2019єми від 5 тонн — за домовленістю.' },
  { question: 'Чи доставляєте по вихідних?', answer: 'Так, працюємо 7 днів на тиждень, диспетчер доступний 24/7.' },
  { question: 'Які форми оплати?', answer: 'Готівка, безготівковий розрахунок, відстрочка до 14 днів постійним клієнтам.' },
  { question: 'Чи є сертифікати якості?', answer: 'Так, на кожну партію надаємо паспорт якості та сертифікат відповідності ДСТУ.' },
] : [
  { question: 'Какая минимальная партия?', answer: 'Стандартный минимум — 1 полная машина (20 тонн ACTROS). Меньшие объёмы от 5 тонн — по договорённости.' },
  { question: 'Доставляете по выходным?', answer: 'Да, работаем 7 дней в неделю, диспетчер 24/7.' },
  { question: 'Какие формы оплаты?', answer: 'Наличные, безналичный расчёт, отсрочка до 14 дней постоянным клиентам.' },
  { question: 'Есть сертификаты качества?', answer: 'Да, на каждую партию предоставляем паспорт качества и сертификат соответствия.' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: isUk ? 'Головна' : 'Главная', href: `/${locale}/` }, { label: isUk ? 'Матеріали' : 'Материалы' }]} />

  <section class="py-16 md:py-24 lg:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6"><span class="block w-8 h-0.5 bg-mt-accent"></span><span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— {isUk ? 'Каталог' : 'Каталог'}</span></div>
      <h1 class="font-display font-black uppercase mb-6" style="font-size: clamp(56px, 12vw, 144px); line-height: 0.85; letter-spacing: -0.04em;">{isUk ? 'СИПУЧІ' : 'СЫПУЧИЕ'}<br/><span class="text-mt-accent">{isUk ? 'МАТЕРІАЛИ' : 'МАТЕРИАЛЫ'}</span></h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[800px] leading-relaxed">{description}</p>
    </div>
  </section>

  <section class="border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24">
      <SectionHeader eyebrow={isUk ? 'КАТАЛОГ' : 'КАТАЛОГ'} titleLine1={isUk ? 'КАТЕГОРІЇ' : 'КАТЕГОРИИ'} titleAccent={isUk ? 'МАТЕРІАЛІВ' : 'МАТЕРИАЛОВ'} meta={[`${sorted.length} ${isUk ? 'ПОЗИЦІЙ' : 'ПОЗИЦИЙ'}`]} />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-mt-divider">
        {sorted.map((entry) => (
          <a href={`/${locale}/materialy/${entry.data.slug}/`} class="group block bg-mt-bg-1 border-r border-b border-mt-divider transition-colors hover:bg-mt-bg-2 hover:border-mt-accent">
            {entry.data.image && (<div class="h-48 md:h-56 overflow-hidden"><img src={entry.data.image} alt={entry.data.title} loading="lazy" class="w-full h-full object-cover brightness-75 grayscale-[30%] transition-transform duration-700 group-hover:scale-[1.06] group-hover:brightness-90 group-hover:grayscale-0" /></div>)}
            <div class="p-6 md:p-8">
              <h3 class="font-display font-black text-lg md:text-xl uppercase tracking-tight mb-2">{entry.data.title}</h3>
              {entry.data.priceFrom && (<div class="flex items-baseline gap-2"><span class="font-mono font-black text-2xl text-mt-accent">{entry.data.priceFrom} ₴</span><span class="font-mono text-[11px] text-mt-tertiary uppercase tracking-widest">/ {isUk ? 'тонна' : 'тонна'}</span></div>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <FAQ items={faq} />
  <CTABanner title={isUk ? 'Потрібен матеріал?' : 'Нужен материал?'} subtitle={isUk ? 'Подзвоніть або напишіть в Telegram.' : 'Позвоните или напишите в Telegram.'} buttonText={isUk ? 'Замовити доставку →' : 'Заказать доставку →'} buttonHref={`/${locale}/kontakty/`} />
</PageLayout>
