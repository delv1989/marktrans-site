---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import SectionHeader from '../../../components/SectionHeader.astro';
import ProductCard from '../../../components/ProductCard.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { shchebenProducts } from '../../../data/products';

const title = 'Щебень с доставкой по Киеву — от 170 ₴/тонна · MARKTRANS';
const description = 'Гранитный щебень всех фракций: 5-10, 5-20, 20-40, 40-70 мм. Цена от 170 ₴/тонна. Доставка самосвалом ACTROS в день заказа.';

const faq = [
  { question: 'Сколько тонн щебня в кубометре?', answer: '1 м³ гранитного щебня фракции 5-20 весит примерно 1.4 тонны. Для фракции 20-40 — около 1.35 тонны.' },
  { question: 'Какой щебень лучше для фундамента?', answer: 'Для ленточного фундамента — гранитный 20-40 мм. Для плитного — 5-20 мм. Морозостойкость не ниже F300.' },
  { question: 'Доставляете ли в Бровары?', answer: 'Да, доставляем по всей Киевской области в радиусе 200 км.' },
  { question: 'Какая минимальная партия?', answer: 'Стандартный минимум — 1 полная машина (20 тонн ACTROS). Меньшие объёмы — по договорённости.' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[
    { label: 'Главная', href: '/ru/' },
    { label: 'Материалы', href: '/ru/' },
    { label: 'Щебень' }
  ]} />

  <section class="py-16 md:py-24 lg:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h1 class="font-display font-black uppercase mb-4" style="font-size: clamp(56px, 12vw, 144px); line-height: 0.85; letter-spacing: -0.04em;">ЩЕБЕНЬ</h1>
      <div class="font-mono text-xs text-mt-tertiary uppercase tracking-widest mb-8">{shchebenProducts.length} позиций · от 170 ₴/тонна</div>
      <p class="text-base md:text-lg text-mt-secondary max-w-[800px] leading-relaxed">
        Гранитный щебень всех стандартных фракций. Цена от 170 ₴/тонна. Доставка самосвалом ACTROS в день заказа.
      </p>
    </div>
  </section>

  <section class="border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 border-t border-l border-mt-divider">
        {shchebenProducts.map((p) => <ProductCard product={p} />)}
      </div>
    </div>
  </section>

  <FAQ items={faq} title="Частые вопросы" />

  <CTABanner title="Не знаете какую фракцию?" subtitle="Позвоните — расскажем и посчитаем." buttonText="Позвонить →" buttonHref="tel:+380504204229" />
</PageLayout>
