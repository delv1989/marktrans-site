---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CTABanner from '../../../components/CTABanner.astro';

const title = 'Блог MARKTRANS — статьи о стройматериалах и логистике';
const description = 'Практические статьи для строителей: как выбрать щебень, рассчитать объём, оптимизировать доставку.';

const articles = [
  { slug: 'yakyi-shcheben-dlya-fundamentu', title: 'Какой щебень выбрать для фундамента: полный гайд', category: 'Материалы', date: '10.04.2026', time: '12 мин' },
  { slug: 'skilky-tonn-v-kubometri', title: 'Сколько тонн щебня в кубометре: таблица и расчёт', category: 'Материалы', date: '05.04.2026', time: '5 мин' },
  { slug: 'granitnyi-vs-vapnyakovyi', title: 'Гранитный vs известняковый щебень: что лучше?', category: 'Технологии', date: '01.04.2026', time: '7 мин' },
  { slug: 'yak-zamovyty-dostavku', title: 'Как заказать доставку щебня правильно', category: 'Логистика', date: '28.03.2026', time: '6 мин' },
  { slug: 'beton-m200-vs-m400', title: 'Бетон М200 или М400: на какой марке остановиться?', category: 'Технологии', date: '20.03.2026', time: '10 мин' },
  { slug: 'vydy-pisku', title: 'Виды песка для строительства: речной, карьерный, мытый', category: 'Материалы', date: '15.03.2026', time: '9 мин' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'Главная', href: '/ru/' }, { label: 'Блог' }]} />

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6"><span class="block w-8 h-0.5 bg-mt-accent"></span><span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Знания для строителей</span></div>
      <h1 class="font-display font-black uppercase mb-4" style="font-size: clamp(80px, 18vw, 240px); line-height: 0.8; letter-spacing: -0.04em;">БЛОГ</h1>
      <div class="font-mono text-xs text-mt-tertiary uppercase tracking-widest">{articles.length} статей · Обновляется еженедельно</div>
    </div>
  </section>

  <section class="border-b border-mt-divider"><div class="max-w-[1440px] mx-auto">
    <div class="divide-y divide-mt-divider border-t border-mt-divider">
      {articles.map((a) => (
        <a href={`/ru/blog/${a.slug}/`} class="group flex flex-col md:flex-row md:items-center justify-between gap-4 px-6 md:px-12 py-8 md:py-10 hover:bg-mt-bg-1 transition-colors">
          <div class="flex-1">
            <div class="flex items-center gap-3 mb-2"><span class="font-mono text-[10px] text-mt-accent uppercase tracking-widest">{a.category}</span><span class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest">{a.date} · {a.time}</span></div>
            <h2 class="font-display font-black text-lg md:text-2xl uppercase tracking-tight group-hover:text-mt-accent transition-colors">{a.title}</h2>
          </div>
          <span class="font-mono font-black text-mt-accent text-xl group-hover:translate-x-2 transition-transform shrink-0">→</span>
        </a>
      ))}
    </div>
  </div></section>

  <CTABanner title="Новая статья раз в неделю" subtitle="Подписывайтесь на Telegram." buttonText="Подписаться →" buttonHref="https://t.me/marktrans_bot" />
</PageLayout>
