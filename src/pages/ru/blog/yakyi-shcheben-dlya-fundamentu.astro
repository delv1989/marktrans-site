---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import FAQ from '../../../components/FAQ.astro';

const title = 'Какой щебень выбрать для фундамента: полный гайд · MARKTRANS';
const description = 'Для ленточного фундамента — гранитный 20-40 мм. Для плитного — 5-20 мм. Таблица фракций, формула расчёта.';

const faq = [
  { question: 'Сколько щебня на 10 м³ бетона?', answer: 'На 1 м³ бетона М200-М300 нужно примерно 1.1-1.2 тонны щебня 5-20 мм. На 10 м³ — около 11-12 тонн.' },
  { question: 'Можно ли смешивать фракции?', answer: 'Да, комбинация 5-20 и 20-40 даёт лучшую плотность заполнения.' },
  { question: 'Доставляете ли в Бровары?', answer: 'Да, Бровары, Ирпень, Вышгород — стандартные маршруты. Доставка в день заказа.' },
  { question: 'Сколько стоит доставка?', answer: 'Базовый выезд до 16 км — 3500 ₴. 17-40 км — +220 ₴/км. 41-200 км — +200 ₴/км.' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'Главная', href: '/ru/' }, { label: 'Блог', href: '/ru/blog/' }, { label: 'Какой щебень для фундамента' }]} />

  <article class="py-16 md:py-24">
    <div class="max-w-[720px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6">
        <span class="px-3 py-1 bg-mt-accent/10 border border-mt-accent text-mt-accent font-mono text-[10px] uppercase tracking-widest rounded-xs">Материалы</span>
        <span class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest">10.04.2026 · 12 мин</span>
      </div>
      <h1 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight leading-none mb-6">Какой щебень выбрать для фундамента: полный гайд</h1>
      <p class="text-lg text-mt-secondary leading-relaxed mb-4">Фракция, прочность, ГОСТ — всё что нужно знать перед заказом.</p>
      <div class="font-mono text-xs text-mt-tertiary uppercase tracking-widest mb-12">Андрей Бойко · Главный диспетчер</div>

      <div class="border-l-4 border-mt-accent pl-6 mb-12">
        <p class="text-lg font-medium text-mt-text leading-relaxed">
          Для ленточного фундамента частного дома оптимальная фракция — <strong class="text-mt-accent">20-40 мм гранитный</strong>.
          Для плитного — <strong class="text-mt-accent">5-20 мм</strong>. Морозостойкость не ниже F300, марка М1000-М1200.
        </p>
      </div>

      <h2 class="font-display font-black text-2xl uppercase tracking-tight mb-6 mt-12">Почему фракция критически важна</h2>
      <p class="text-mt-secondary leading-relaxed mb-8">Фракция щебня напрямую влияет на прочность бетона, плотность заполнения и способность фундамента выдерживать нагрузки. Неправильный выбор — это трещины через 2-3 года.</p>

      <h2 class="font-display font-black text-2xl uppercase tracking-tight mb-6 mt-12">Таблица: какая фракция для какого фундамента</h2>
      <div class="border border-mt-divider divide-y divide-mt-divider mb-8 text-sm">
        {[['Ленточный', '20-40 мм', 'Оптимальное соотношение прочности и веса'], ['Плитный', '5-20 мм', 'Равномерное заполнение тонких слоёв'], ['Свайный', '20-40 мм', 'Плотное уплотнение между сваями'], ['Столбчатый', '5-20 мм', 'Мелкая фракция для локальных точек']].map(([type, fraction, reason]) => (
          <div class="flex"><div class="w-1/3 px-4 py-3 font-bold border-r border-mt-divider">{type}</div><div class="w-1/3 px-4 py-3 font-mono text-mt-accent font-bold border-r border-mt-divider">{fraction}</div><div class="w-1/3 px-4 py-3 text-mt-secondary">{reason}</div></div>
        ))}
      </div>

      <h2 class="font-display font-black text-2xl uppercase tracking-tight mb-6 mt-12">Как рассчитать нужный объём</h2>
      <div class="bg-mt-bg-1 border border-mt-divider border-l-4 border-l-mt-accent p-6 font-mono text-sm mb-8">
        <div class="text-mt-accent font-bold mb-2">Формула:</div>
        <div>Объём = Длина × Ширина × Толщина × 1.1</div>
        <div>Масса (т) = Объём (м³) × 1.4</div>
      </div>
      <p class="text-mt-secondary leading-relaxed mb-8"><strong class="text-mt-text">Пример:</strong> Фундамент 10м × 8м × 0.15м = 12 м³ × 1.4 = <strong class="text-mt-accent">16.8 тонн</strong>.</p>

      <h2 class="font-display font-black text-2xl uppercase tracking-tight mb-6 mt-12">Выводы</h2>
      <ol class="space-y-3 text-sm text-mt-secondary list-decimal list-inside mb-12">
        <li>Для ленточного — <strong class="text-mt-accent">гранитный 20-40 мм</strong></li>
        <li>Для плитного — <strong class="text-mt-accent">5-20 мм</strong></li>
        <li>Морозостойкость — не ниже <strong class="text-mt-accent">F300</strong></li>
        <li>Марка прочности — <strong class="text-mt-accent">М1000-М1200</strong></li>
      </ol>
    </div>
  </article>

  <section class="border-y border-mt-divider"><div class="max-w-[1440px] mx-auto grid grid-cols-2 md:grid-cols-4">
    {[{ v:'1400', l:'КГ/М³' },{ v:'М1200', l:'МАРКА' },{ v:'F300', l:'МОРОЗ.' },{ v:'265 ₴', l:'ЦЕНА 5-10/Т' }].map((s)=>(
      <div class="px-6 py-8 border-r border-mt-divider last:border-r-0 text-center"><div class="font-mono font-black text-2xl md:text-3xl text-mt-accent leading-none mb-2">{s.v}</div><div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest">{s.l}</div></div>
    ))}
  </div></section>

  <section class="bg-mt-accent py-12 md:py-16"><div class="max-w-[720px] mx-auto px-6 md:px-12 text-center">
    <h2 class="font-display font-black text-2xl md:text-3xl text-mt-accent-contrast uppercase tracking-tight mb-4">Нужен гранитный щебень 20-40 мм?</h2>
    <p class="text-mt-accent-contrast/80 mb-8">Доставка по Киеву — от 245 ₴/тонна</p>
    <a href="/ru/kontakty/" class="inline-flex items-center gap-3 px-10 py-4 bg-mt-bg text-mt-text font-display font-black uppercase tracking-wider rounded-xs hover:bg-mt-bg-2 transition-colors">Заказать →</a>
  </div></section>

  <FAQ items={faq} title="Вопросы к статье" />
</PageLayout>
