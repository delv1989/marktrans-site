---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';

const title = 'О компании MARKTRANS — доставка стройматериалов с 2015 года';
const description = 'MARKTRANS — семейная компания из Киева. Собственный автопарк 5 самосвалов ACTROS.';

const timeline = [
  { year: '2015', title: 'Первый ACTROS', text: 'Владимир Ткаченко покупает первый самосвал и начинает возить щебень по Киевщине.' },
  { year: '2017', title: 'Расширение', text: 'Автопарк растёт до 3 машин. Добавляем услугу аренды спецтехники.' },
  { year: '2019', title: 'Первый гостендер', text: 'Побеждаем в тендере Укравтодора.' },
  { year: '2021', title: 'Автопарк 5 машин', text: 'Добавляем ещё 2 ACTROS. Привлекаем постоянных диспетчеров 24/7.' },
  { year: '2023', title: 'Цифровая трансформация', text: 'Запускаем Telegram-бот для заказов и внутреннюю CRM.' },
  { year: '2026', title: 'Новая платформа', text: 'Полный редизайн сайта, современный стек, AI-оптимизация.' },
];

const stats = [
  { value: '2015', label: 'Год основания' }, { value: '5', label: 'Самосвалов ACTROS' },
  { value: '12 000+', label: 'Выполненных рейсов' }, { value: '200K', label: 'Тонн перевезено' },
  { value: '38', label: 'Постоянных клиентов' }, { value: '24/7', label: 'Диспетчер' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'Главная', href: '/ru/' }, { label: 'О компании' }]} />

  <section class="py-16 md:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6"><span class="block w-8 h-0.5 bg-mt-accent"></span><span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Established 2015</span></div>
      <h1 class="font-display font-black uppercase mb-8" style="font-size: clamp(64px, 12vw, 160px); line-height: 0.85; letter-spacing: -0.04em;">MARKTRANS</h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[720px] leading-relaxed">Семейная компания из Киева. Собственный автопарк, собственный опыт, собственная ответственность за каждый рейс.</p>
    </div>
  </section>

  <section class="border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6">
      {stats.map((s) => (
        <div class="px-6 py-10 border-r border-b border-mt-divider last:border-r-0">
          <div class="font-mono font-black text-3xl md:text-4xl text-mt-accent leading-none mb-2">{s.value}</div>
          <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight mb-12">Наша история</h2>
      <div class="relative pl-8 md:pl-12 border-l-2 border-mt-accent space-y-10">
        {timeline.map((item) => (
          <div class="relative">
            <div class="absolute -left-[calc(2rem+5px)] md:-left-[calc(3rem+5px)] top-1 w-2.5 h-2.5 bg-mt-accent rounded-full"></div>
            <div class="font-mono font-black text-2xl text-mt-accent leading-none mb-2">{item.year}</div>
            <div class="font-display font-black text-lg uppercase tracking-tight mb-1">{item.title}</div>
            <p class="text-sm text-mt-secondary leading-relaxed max-w-[640px]">{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner title="Нужен надёжный поставщик?" subtitle="Работаем по всей Киевской области." buttonText="Заказать рейс →" buttonHref="/ru/kontakty/" />
</PageLayout>
