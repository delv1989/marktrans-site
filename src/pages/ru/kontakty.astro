---
import PageLayout from '../../layouts/PageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { contacts } from '../../data/navigation';

const title = 'Контакты MARKTRANS — телефон, адрес, карта · Киев';
const description = 'MARKTRANS работает 24/7. Телефон: +38 050 420 42 29. Адрес: Киев, ул. Жилянская, 101.';
const addr = contacts.address.ru;

const cards = [
  { label: 'Телефон', value: contacts.phones[0], subvalue: contacts.phones[1], href: `tel:${contacts.phonesRaw[0]}`, sub: 'Круглосуточно · Пн-Вс', btn: 'Позвонить', primary: true },
  { label: 'Telegram', value: '@marktrans_bot', href: 'https://t.me/marktrans_bot', target: '_blank', sub: 'Мгновенные заказы', btn: 'Открыть бот', primary: true },
  { label: 'Email', value: contacts.email, href: `mailto:${contacts.email}`, sub: 'Ответ в течение 1 часа', btn: 'Написать', primary: false },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'Главная', href: '/ru/' }, { label: 'Контакты' }]} />

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6"><span class="block w-8 h-0.5 bg-mt-accent"></span><span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Свяжитесь с нами</span></div>
      <h1 class="font-display font-black uppercase mb-6" style="font-size: clamp(56px, 12vw, 144px); line-height: 0.85; letter-spacing: -0.04em;">КОНТАКТЫ</h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[720px] leading-relaxed">MARKTRANS работает 24/7. Диспетчер принимает заказы круглосуточно. Офис: {addr.city}, {addr.street}.</p>
    </div>
  </section>

  <div class="bg-mt-accent py-3 px-6"><div class="max-w-[1440px] mx-auto flex items-center justify-center gap-3 font-mono text-sm font-bold text-mt-accent-contrast"><span class="w-2 h-2 bg-mt-accent-contrast rounded-full animate-pulse"></span>Открыто сейчас · Диспетчер на связи</div></div>

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-mt-divider border border-mt-divider">
        {cards.map((c) => (
          <div class="bg-mt-bg-1 p-8 md:p-10 flex flex-col">
            <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest mb-4">{c.label}</div>
            <div class="font-mono font-black text-xl md:text-2xl text-mt-accent leading-tight mb-1">{c.value}</div>
            {c.subvalue && <div class="font-mono font-bold text-base text-mt-text mb-2">{c.subvalue}</div>}
            <div class="text-xs text-mt-tertiary mb-6">{c.sub}</div>
            <a href={c.href} target={c.target} rel={c.target ? 'noopener noreferrer' : undefined}
              class:list={['mt-auto w-full text-center py-3.5 font-display font-black text-sm uppercase tracking-wider rounded-xs transition-all',
                c.primary ? 'bg-mt-accent text-mt-accent-contrast hover:bg-mt-accent-hover' : 'bg-transparent text-mt-text border-2 border-mt-divider hover:border-mt-accent hover:text-mt-accent'
              ]}>{c.btn}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <h2 class="font-display font-black text-2xl uppercase tracking-tight mb-8">Адрес и реквизиты</h2>
          <div class="space-y-4 font-mono text-sm">
            <div class="flex items-baseline gap-3"><span class="text-mt-tertiary text-[10px] uppercase tracking-widest min-w-[80px]">Адрес</span><span class="font-bold">{addr.city}, {addr.street}</span></div>
            <div class="flex items-baseline gap-3"><span class="text-mt-tertiary text-[10px] uppercase tracking-widest min-w-[80px]">Часы</span><span class="font-bold">{contacts.hours.ru}</span></div>
            <div class="border-t border-mt-divider my-6"></div>
            {contacts.phones.map((p, i) => (
              <div class="flex items-baseline gap-3"><span class="text-mt-tertiary text-[10px] uppercase tracking-widest min-w-[80px]">{i === 0 ? 'Телефон' : ''}</span><a href={`tel:${contacts.phonesRaw[i]}`} class="font-bold hover:text-mt-accent transition-colors">{p}</a></div>
            ))}
            <div class="flex items-baseline gap-3"><span class="text-mt-tertiary text-[10px] uppercase tracking-widest min-w-[80px]">Email</span><a href={`mailto:${contacts.email}`} class="font-bold hover:text-mt-accent transition-colors break-all">{contacts.email}</a></div>
          </div>
        </div>
        <div>
          <h2 class="font-display font-black text-2xl uppercase tracking-tight mb-8">На карте</h2>
          <div class="relative aspect-[4/3] border border-mt-divider overflow-hidden bg-mt-bg-1">
            <div class="absolute top-4 left-4 z-10 flex items-center gap-2 bg-mt-bg px-4 py-2.5 border border-mt-divider pointer-events-none"><span class="w-2 h-2 bg-mt-accent rounded-full animate-pulse"></span><span class="font-mono text-[10px] text-mt-accent uppercase tracking-widest">MARKTRANS · Офис</span></div>
            <iframe src="https://maps.google.com/maps?q=%D0%9A%D0%B8%D0%B5%D0%B2%20%D1%83%D0%BB.%20%D0%96%D0%B8%D0%BB%D1%8F%D0%BD%D1%81%D0%BA%D0%B0%D1%8F%20101&t=&z=15&ie=UTF8&iwloc=&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="MARKTRANS на карте" class="w-full h-full border-0" style="filter: grayscale(100%) invert(92%) hue-rotate(180deg) contrast(85%);"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <h2 class="font-display font-black text-3xl md:text-5xl uppercase tracking-tight mb-12">Зона доставки</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-mt-divider border border-mt-divider">
        {[{ range: 'До 16 км', price: '3500 ₴', note: 'Базовый выезд' }, { range: '17-40 км', price: '+220 ₴/км', note: 'Киевская область' }, { range: '41-200 км', price: '+200 ₴/км', note: 'Дальняя область' }].map((z) => (
          <div class="bg-mt-bg p-8 md:p-10 text-center">
            <div class="font-display font-black text-lg uppercase tracking-tight mb-2">{z.range}</div>
            <div class="font-mono font-black text-3xl md:text-4xl text-mt-accent leading-none mb-3">{z.price}</div>
            <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest">{z.note}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
