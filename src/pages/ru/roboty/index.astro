---
import PageLayout from '../../../layouts/PageLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import CategoryGrid from '../../../components/CategoryGrid.astro';
import FAQ from '../../../components/FAQ.astro';
import CTABanner from '../../../components/CTABanner.astro';
import { works } from '../../../data/content';

const title = 'Строительные работы Киев — асфальтирование, земляные работы, демонтаж · MARKTRANS';
const description = 'Полный цикл строительных работ собственной техникой. Киев и Киевская область.';

const faq = [
  { question: 'Работаете с юрлицами?', answer: 'Да, подписываем договор подряда с ООО и ФЛП. Акты, счета, сметы.' },
  { question: 'Какой минимальный объём работ?', answer: 'Асфальтирование — от 100 м². Земляные работы — от 1 смены (8 часов). Вывоз грунта — от 1 машины (20 тонн).' },
  { question: 'Предоставляете смету?', answer: 'Да, бесплатная предварительная смета после осмотра объекта.' },
];
---

<PageLayout title={title} description={description}>
  <Breadcrumbs items={[{ label: 'Главная', href: '/ru/' }, { label: 'Строительные работы' }]} />

  <section class="py-16 md:py-24 lg:py-32 border-b border-mt-divider">
    <div class="max-w-[1440px] mx-auto px-6 md:px-12">
      <div class="flex items-center gap-3 mb-6"><span class="block w-8 h-0.5 bg-mt-accent"></span><span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.2em]">— Услуги</span></div>
      <h1 class="font-display font-black uppercase mb-6" style="font-size: clamp(48px, 10vw, 120px); line-height: 0.88; letter-spacing: -0.03em;">СТРОИТЕЛЬНЫЕ<br/><span class="text-mt-accent">РАБОТЫ</span></h1>
      <p class="text-base md:text-lg text-mt-secondary max-w-[720px] leading-relaxed">Полный цикл строительных работ собственной техникой. Киев и Киевская область.</p>
    </div>
  </section>

  <section class="border-b border-mt-divider"><div class="max-w-[1440px] mx-auto px-6 md:px-12 py-16 md:py-24"><CategoryGrid items={works} columns={4} /></div></section>

  <FAQ items={faq} title="Вопросы о работах" />
  <CTABanner title="Нужны строительные работы?" subtitle="Бесплатная смета после осмотра." buttonText="Заказать осмотр →" buttonHref="/ru/kontakty/" />
</PageLayout>
