---
interface Props {
  num: string;
  title: string;
  subtitle?: string;
  image: string;
  href: string;
  alt: string;
  detailLabel?: string;
}
const {
  num,
  title,
  subtitle,
  image,
  href,
  alt,
  detailLabel = 'Детальніше →',
} = Astro.props;

// title може містити \n для переносу
const titleLines = title.split('\n');
---

<a
  href={href}
  class="group relative block aspect-[4/3] overflow-hidden bg-mt-bg-1 border-r border-b border-mt-divider cursor-pointer"
>
  <!-- Image -->
  <img
    src={image}
    alt={alt}
    loading="lazy"
    decoding="async"
    class="absolute inset-0 w-full h-full object-cover transition-all duration-700 ease-out brightness-75 contrast-125 group-hover:scale-[1.06] group-hover:brightness-90"
    style="filter: grayscale(35%) contrast(1.15) brightness(0.75);"
  />

  <!-- Dark gradient overlay -->
  <div
    class="absolute inset-0 flex flex-col justify-end p-6 md:p-8 lg:p-10"
    style="background: linear-gradient(180deg, transparent 0%, rgba(15,15,15,0.35) 45%, rgba(15,15,15,0.96) 100%);"
  >
    <!-- Number -->
    <div class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.15em] mb-3">
      {num}{subtitle && ` / ${subtitle}`}
    </div>

    <!-- Title -->
    <h3
      class="font-display font-black uppercase mb-4"
      style="font-size: clamp(22px, 2.4vw, 40px); line-height: 0.95; letter-spacing: -0.02em; text-shadow: 0 2px 16px rgba(0,0,0,0.5);"
    >
      {
        titleLines.map((line, i) => (
          <>
            {line}
            {i < titleLines.length - 1 && <br />}
          </>
        ))
      }
    </h3>

    <!-- Arrow -->
    <div class="flex items-center gap-2 font-display font-black text-[13px] text-mt-accent uppercase tracking-widest opacity-85 group-hover:opacity-100 group-hover:gap-3.5 transition-all">
      {detailLabel}
    </div>
  </div>
</a>
