---
// Sticky CTA тільки на мобільних — прямий tel: call
// +20-40% конверсія для B2B за фідбеком
import { contacts } from '../data/navigation';

const locale = (Astro.currentLocale ?? 'uk') as 'uk' | 'ru';
const label = locale === 'uk' ? 'Подзвонити · 050 420 42 29' : 'Позвонить · 050 420 42 29';
---

<a
  href={`tel:${contacts.phonesRaw[0]}`}
  id="stickyMobileCta"
  class="lg:hidden fixed bottom-0 inset-x-0 z-40 bg-mt-accent text-mt-accent-contrast font-display font-black text-sm uppercase tracking-widest text-center py-5 shadow-[0_-8px_24px_rgba(0,0,0,0.4)] border-t-2 border-mt-accent-dim flex items-center justify-center gap-3 transition-transform duration-300"
  aria-label={label}
>
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
  </svg>
  {label}
</a>

<!-- Safe area padding + auto-hide on scroll down -->
<style>
  @media (max-width: 1023px) {
    body { padding-bottom: 72px; }
  }
</style>
<script>
  (function() {
    const cta = document.getElementById('stickyMobileCta');
    const fab = document.getElementById('messengerFab');
    const ai = document.getElementById('aiAssistant');
    if (!cta) return;
    let lastY = 0;
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const y = window.scrollY;
        const down = y > lastY && y > 200;
        cta.style.transform = down ? 'translateY(100%)' : '';
        if (fab) fab.style.transition = 'opacity 300ms';
        if (fab) fab.style.opacity = down ? '0.3' : '1';
        if (ai) ai.style.transition = 'opacity 300ms';
        if (ai) ai.style.opacity = down ? '0.3' : '1';
        lastY = y;
        ticking = false;
      });
    }, { passive: true });
  })();
</script>
