---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
const locale = Astro.url.pathname.startsWith('/ru/') ? 'ru' : 'uk';
---

<a href={`/${locale}/`} class={`flex items-center gap-3 shrink-0 group ${className}`}>
  <span class="flex items-center gap-1.5">
    <span class="block w-1 h-7 bg-mt-accent transition-all group-hover:h-8"></span>
    <svg class="w-7 h-7" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="10" width="18" height="12" fill="#FFD700"/>
      <rect x="20" y="14" width="10" height="8" fill="#FFFFFF"/>
      <circle cx="8" cy="25" r="3" fill="#FFFFFF" stroke="#FFD700" stroke-width="1.5"/>
      <circle cx="24" cy="25" r="3" fill="#FFFFFF" stroke="#FFD700" stroke-width="1.5"/>
    </svg>
  </span>
  <span class="font-display font-black text-[22px] tracking-tight uppercase text-mt-text">
    MARKTRANS
  </span>
</a>
