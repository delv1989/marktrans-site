---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  buttonText: string;
  buttonHref: string;
}
const { eyebrow, title, subtitle, buttonText, buttonHref } = Astro.props;
---

<section class="bg-mt-accent py-16 md:py-24">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12 text-center md:text-left">
    {eyebrow && (
      <div class="font-mono text-[11px] text-mt-accent-contrast/60 uppercase tracking-widest mb-6">— {eyebrow}</div>
    )}
    <h2
      class="font-display font-black text-mt-accent-contrast uppercase mb-6"
      style="font-size: clamp(40px, 8vw, 96px); line-height: 0.85; letter-spacing: -0.03em;"
    >
      {title}
    </h2>
    {subtitle && (
      <p class="text-lg text-mt-accent-contrast/80 max-w-[640px] mb-10">{subtitle}</p>
    )}
    <a
      href={buttonHref}
      class="inline-flex items-center gap-3 px-10 py-5 bg-mt-bg text-mt-text font-display font-black text-base uppercase tracking-wider rounded-xs hover:bg-mt-bg-2 transition-colors"
    >
      {buttonText}
    </a>
  </div>
</section>
