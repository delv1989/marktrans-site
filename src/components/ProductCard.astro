---
import type { Product } from '../data/products';

interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<a
  href={`/uk/materialy/${product.slug}/`}
  class="group block bg-mt-bg-1 border-r border-b border-mt-divider transition-colors hover:bg-mt-bg-2 hover:border-mt-accent"
>
  <div class="relative h-48 md:h-56 overflow-hidden">
    <img
      src={product.image}
      alt={product.alt}
      loading="lazy"
      decoding="async"
      class="w-full h-full object-cover brightness-75 contrast-[1.15] grayscale-[35%] transition-transform duration-700 group-hover:scale-[1.06] group-hover:brightness-90 group-hover:grayscale-0"
    />
    {product.badge && (
      <span class="absolute top-4 left-4 font-mono text-[10px] text-mt-accent uppercase tracking-widest bg-mt-bg/80 px-2.5 py-1 border border-mt-accent/30 rounded-xs">
        {product.badge}
      </span>
    )}
  </div>
  <div class="p-6 md:p-8">
    <h3 class="font-display font-black text-xl md:text-2xl uppercase tracking-tight mb-1">{product.name}</h3>
    {product.spec && (
      <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest mb-6">{product.spec}</div>
    )}
    <div class="border-t border-mt-divider pt-5 flex items-baseline justify-between">
      <span class="font-mono font-black text-2xl md:text-3xl text-mt-accent leading-none tracking-tight">{product.price} ₴</span>
      <span class="font-mono text-[11px] text-mt-tertiary uppercase tracking-widest">/ {product.unit}</span>
    </div>
  </div>
</a>
