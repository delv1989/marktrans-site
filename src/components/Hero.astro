---
interface Props {
  eyebrow: string;
  titleLine1: string;
  titleLine2: string;
  titleAccent: string;
  lead: string;
  ctaPrimary: string;
  ctaSecondary: string;
  ctaPrimaryHref?: string;
  ctaSecondaryHref?: string;
  bgImage: string;
}

const {
  eyebrow,
  titleLine1,
  titleLine2,
  titleAccent,
  lead,
  ctaPrimary,
  ctaSecondary,
  ctaPrimaryHref = '#contacts',
  ctaSecondaryHref = '#materials',
  bgImage,
} = Astro.props;
---

<section class="relative min-h-[88vh] md:min-h-[92vh] flex items-center py-20 md:py-32 overflow-hidden">
  <!-- Background image -->
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image: linear-gradient(135deg, rgba(15,15,15,0.85) 0%, rgba(15,15,15,0.4) 55%, rgba(15,15,15,0.9) 100%), url(${bgImage});`}
    aria-hidden="true"
  ></div>

  <!-- Bottom fade to bg -->
  <div
    class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-b from-transparent to-mt-bg pointer-events-none"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 max-w-[1440px] mx-auto px-6 md:px-12 w-full">
    <div class="max-w-[1100px] mx-auto text-center">
      <!-- Eyebrow -->
      <div class="flex items-center justify-center gap-3 mb-6 md:mb-8">
        <span class="block w-8 md:w-10 h-0.5 bg-mt-accent"></span>
        <span class="font-mono text-[11px] md:text-xs text-mt-accent uppercase tracking-[0.2em]">
          {eyebrow}
        </span>
        <span class="block w-8 md:w-10 h-0.5 bg-mt-accent"></span>
      </div>

      <!-- Huge headline -->
      <h1
        class="font-display font-black uppercase mb-8 md:mb-10"
        style="font-size: clamp(48px, 9vw, 140px); line-height: 0.88; letter-spacing: -0.03em; text-shadow: 0 2px 40px rgba(0, 0, 0, 0.6);"
      >
        {titleLine1}<br />
        {titleLine2}<br />
        <span class="text-mt-accent">{titleAccent}</span>
      </h1>

      <!-- Lead -->
      <p class="text-base md:text-lg lg:text-xl text-[#DDDDDD] max-w-[680px] mx-auto leading-relaxed mb-10 md:mb-14">
        {lead}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4 items-stretch sm:items-center justify-center">
        <a href={ctaPrimaryHref} class="btn-primary justify-center">
          {ctaPrimary}
        </a>
        <a href={ctaSecondaryHref} class="btn-secondary justify-center">
          {ctaSecondary}
        </a>
      </div>

      <!-- Mini stats -->
      <div class="mt-16 md:mt-20 flex flex-wrap justify-center gap-6 md:gap-16">
        <div class="pl-4 border-l-2 border-mt-accent text-left">
          <div class="font-mono font-black text-2xl md:text-3xl lg:text-4xl text-mt-text leading-none">5</div>
          <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest mt-1.5">Самоскидів ACTROS</div>
        </div>
        <div class="pl-4 border-l-2 border-mt-accent text-left">
          <div class="font-mono font-black text-2xl md:text-3xl lg:text-4xl text-mt-text leading-none">10+</div>
          <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest mt-1.5">Років досвіду</div>
        </div>
        <div class="pl-4 border-l-2 border-mt-accent text-left">
          <div class="font-mono font-black text-2xl md:text-3xl lg:text-4xl text-mt-text leading-none">200км</div>
          <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest mt-1.5">Радіус доставки</div>
        </div>
        <div class="pl-4 border-l-2 border-mt-accent text-left">
          <div class="font-mono font-black text-2xl md:text-3xl lg:text-4xl text-mt-text leading-none">24/7</div>
          <div class="font-mono text-[10px] text-mt-tertiary uppercase tracking-widest mt-1.5">Диспетчер</div>
        </div>
      </div>
    </div>
  </div>
</section>
