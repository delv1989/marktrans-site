---
interface Props {
  eyebrow: string;
  titleLine1: string;
  titleAccent: string;
  meta?: string[];
}
const { eyebrow, titleLine1, titleAccent, meta = [] } = Astro.props;
---

<div class="flex flex-wrap justify-between items-end gap-6 mb-12 md:mb-16">
  <div>
    <div class="flex items-center gap-3 mb-4">
      <span class="block w-8 h-0.5 bg-mt-accent"></span>
      <span class="font-mono text-[11px] text-mt-accent uppercase tracking-[0.15em]">
        {eyebrow}
      </span>
    </div>
    <h2
      class="font-display font-black uppercase max-w-[900px]"
      style="font-size: clamp(36px, 6vw, 96px); line-height: 0.85; letter-spacing: -0.03em;"
    >
      {titleLine1}<br /><span class="text-mt-accent">{titleAccent}</span>
    </h2>
  </div>
  {
    meta.length > 0 && (
      <div class="font-mono text-[11px] text-mt-tertiary uppercase tracking-widest text-right leading-relaxed">
        {meta.map((line) => (
          <div>{line}</div>
        ))}
      </div>
    )
  }
</div>
