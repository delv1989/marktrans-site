---
// FAQ accordion with FAQPage JSON-LD schema
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  items: FaqItem[];
  title?: string;
}

const { items, title = 'Часті запитання' } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<section class="py-16 md:py-24 border-b border-mt-divider">
  <div class="max-w-[1440px] mx-auto px-6 md:px-12">
    <h2 class="font-display font-black text-2xl md:text-4xl uppercase tracking-tight mb-10 md:mb-14">
      {title}
    </h2>

    <div class="divide-y divide-mt-divider border-y border-mt-divider">
      {items.map((item) => (
        <details class="group">
          <summary class="flex items-center justify-between gap-4 py-5 md:py-6 px-2 cursor-pointer list-none font-body text-sm md:text-base text-mt-text hover:text-mt-accent transition-colors [&::-webkit-details-marker]:hidden">
            <span>{item.question}</span>
            <svg
              class="w-5 h-5 shrink-0 text-mt-accent transition-transform duration-200 group-open:rotate-45"
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <line x1="10" y1="4" x2="10" y2="16" />
              <line x1="4" y1="10" x2="16" y2="10" />
            </svg>
          </summary>
          <div class="pb-5 md:pb-6 px-2 text-sm text-mt-secondary leading-relaxed max-w-[800px]">
            {item.answer}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
