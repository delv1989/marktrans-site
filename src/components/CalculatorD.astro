---
import CalculatorShell from './CalculatorShell.astro';
import { CONCRETE_GRADES } from '../lib/density';

interface Props {
  locale: 'uk' | 'ru';
}
const { locale } = Astro.props;
const isUk = locale === 'uk';

const gradesData = CONCRETE_GRADES.map(g => ({ mark: g.mark, cls: g.cls, usage: g[locale] }));
---
<CalculatorShell
  title={isUk ? 'Калькулятор бетону для фундаменту' : 'Калькулятор бетона для фундамента'}
  subtitle={isUk ? 'Розрахуйте обʼєм та рекомендовану марку' : 'Рассчитайте объём и рекомендуемую марку'}
>
  <div data-calc-d>
    <div class="space-y-3">
      <div>
        <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Тип фундаменту' : 'Тип фундамента'}</label>
        <select name="cd-ftype" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors">
          <option value="strip">{isUk ? 'Стрічковий' : 'Ленточный'}</option>
          <option value="slab">{isUk ? 'Монолітна плита' : 'Монолитная плита'}</option>
          <option value="pile">{isUk ? 'Пальово-ростверковий' : 'Свайно-ростверковый'}</option>
        </select>
      </div>
      <div>
        <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Поверховість' : 'Этажность'}</label>
        <select name="cd-floors" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors">
          <option value="1">{isUk ? '1 поверх' : '1 этаж'}</option>
          <option value="2" selected>{isUk ? '2 поверхи' : '2 этажа'}</option>
          <option value="3">{isUk ? '3+ поверхи' : '3+ этажей'}</option>
        </select>
      </div>

      <!-- Strip -->
      <div data-cd-strip class="space-y-3">
        <div>
          <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Периметр стрічки (м)' : 'Периметр ленты (м)'}</label>
          <input type="number" name="cd-perimeter" min="1" step="0.5" placeholder="40" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors" />
        </div>
        <div>
          <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Товщина стрічки (м)' : 'Толщина ленты (м)'}</label>
          <input type="number" name="cd-swidth" min="0.2" step="0.05" placeholder="0.4" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors" />
        </div>
        <div>
          <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Висота стрічки (м)' : 'Высота ленты (м)'}</label>
          <input type="number" name="cd-sheight" min="0.3" step="0.05" placeholder="0.8" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors" />
        </div>
      </div>

      <!-- Slab -->
      <div data-cd-slab class="space-y-3" hidden>
        <div>
          <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Довжина плити (м)' : 'Длина плиты (м)'}</label>
          <input type="number" name="cd-slength" min="1" step="0.1" placeholder="10" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors" />
        </div>
        <div>
          <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Ширина плити (м)' : 'Ширина плиты (м)'}</label>
          <input type="number" name="cd-slabw" min="1" step="0.1" placeholder="8" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors" />
        </div>
        <div>
          <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Товщина плити (м)' : 'Толщина плиты (м)'}</label>
          <input type="number" name="cd-slabt" min="0.15" step="0.05" placeholder="0.25" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors" />
        </div>
      </div>

      <!-- Pile -->
      <div data-cd-pile class="space-y-3" hidden>
        <div>
          <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Діаметр палі (м)' : 'Диаметр сваи (м)'}</label>
          <input type="number" name="cd-pdiam" min="0.15" step="0.05" placeholder="0.3" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors" />
        </div>
        <div>
          <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Глибина палі (м)' : 'Глубина сваи (м)'}</label>
          <input type="number" name="cd-pdepth" min="1" step="0.5" placeholder="3" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors" />
        </div>
        <div>
          <label class="block text-[11px] font-semibold text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Кількість паль' : 'Количество свай'}</label>
          <input type="number" name="cd-pcount" min="1" step="1" placeholder="12" class="w-full px-3 py-2.5 bg-mt-bg border border-mt-divider text-mt-text text-sm focus:outline-none focus:border-mt-accent transition-colors" />
        </div>
      </div>
    </div>

    <!-- Result -->
    <div data-cd-result class="mt-5 p-4 bg-mt-accent/5 border-l-[3px] border-mt-accent" hidden>
      <div class="text-[11px] text-mt-secondary uppercase tracking-widest mb-1">{isUk ? 'Вам потрібно' : 'Вам нужно'}</div>
      <div class="font-mono font-black text-4xl text-mt-accent leading-none mb-2">
        <span data-cd-vol>0</span> <span class="text-lg">м³</span>
      </div>
      <div class="text-sm text-mt-text mb-1">
        {isUk ? 'Рекомендована марка' : 'Рекомендуемая марка'}: <strong data-cd-grade>—</strong> (<span data-cd-cls>—</span>)
      </div>
      <div class="text-sm text-mt-secondary mb-1">
        {isUk ? 'Застосування' : 'Применение'}: <span data-cd-usage>—</span>
      </div>
      <div class="flex flex-wrap gap-3 mt-4">
        <button type="button" data-cd-order class="flex-1 min-w-[160px] py-3 bg-mt-accent text-mt-accent-contrast font-display font-black text-xs uppercase tracking-widest hover:bg-mt-accent-hover transition-colors">
          {isUk ? 'Замовити прорахунок' : 'Заказать просчёт'}
        </button>
      </div>
      <p class="mt-3 text-[11px] text-mt-tertiary italic">{isUk ? 'Ціна бетону залежить від марки і постачальника — диспетчер назве актуальну. Обʼєм включає +5% на втрати.' : 'Цена бетона зависит от марки и поставщика — диспетчер назовёт актуальную. Объём включает +5% на потери.'}</p>
    </div>
  </div>
</CalculatorShell>

<script define:vars={{ gradesData }}>
{
  const root = document.querySelector('[data-calc-d]');
  if (root) {
    const result = root.querySelector('[data-cd-result]');
    const volEl = root.querySelector('[data-cd-vol]');
    const gradeEl = root.querySelector('[data-cd-grade]');
    const clsEl = root.querySelector('[data-cd-cls]');
    const usageEl = root.querySelector('[data-cd-usage]');
    const orderBtn = root.querySelector('[data-cd-order]');
    const stripBlock = root.querySelector('[data-cd-strip]');
    const slabBlock = root.querySelector('[data-cd-slab]');
    const pileBlock = root.querySelector('[data-cd-pile]');

    function val(n) { return parseFloat(root.querySelector(`[name="${n}"]`)?.value) || 0; }

    function recGrade(ftype, floors) {
      if (ftype === 'pile') return gradesData[4];
      if (ftype === 'slab') return floors >= 3 ? gradesData[4] : gradesData[3];
      if (floors === 1) return gradesData[2];
      if (floors === 2) return gradesData[3];
      return gradesData[4];
    }

    function calcVol(ftype) {
      if (ftype === 'strip') return val('cd-perimeter') * val('cd-swidth') * val('cd-sheight');
      if (ftype === 'slab') return val('cd-slength') * val('cd-slabw') * val('cd-slabt');
      if (ftype === 'pile') { const r = val('cd-pdiam') / 2; return Math.PI * r * r * val('cd-pdepth') * val('cd-pcount'); }
      return 0;
    }

    function showFields() {
      const t = root.querySelector('[name="cd-ftype"]').value;
      stripBlock.hidden = t !== 'strip';
      slabBlock.hidden = t !== 'slab';
      pileBlock.hidden = t !== 'pile';
    }

    function calc() {
      const ftype = root.querySelector('[name="cd-ftype"]').value;
      const floors = parseInt(root.querySelector('[name="cd-floors"]').value) || 2;
      const raw = calcVol(ftype);
      if (raw <= 0) { result.hidden = true; return; }

      const withReserve = raw * 1.05;
      const rounded = Math.ceil(withReserve * 10) / 10;
      const grade = recGrade(ftype, floors);

      volEl.textContent = rounded.toFixed(1);
      gradeEl.textContent = grade.mark;
      clsEl.textContent = grade.cls;
      usageEl.textContent = grade.usage;
      result.hidden = false;

      // Fill OrderForm
      const of = document.getElementById('order-form');
      if (of) {
        const msg = of.querySelector('[name="message"]');
        if (msg) msg.value = `Бетон ${grade.mark} для фундаменту (${ftype}), ${rounded} м³, ${floors} пов.`;
      }
    }

    root.addEventListener('input', calc);
    root.addEventListener('change', (e) => {
      if (e.target.name === 'cd-ftype') showFields();
      calc();
    });

    orderBtn.addEventListener('click', () => {
      const target = document.getElementById('order-form');
      if (target) { target.scrollIntoView({ behavior: 'smooth' }); const inp = target.querySelector('input[name="name"]'); if (inp) setTimeout(() => inp.focus(), 400); }
    });

    showFields();
  }
}
</script>
