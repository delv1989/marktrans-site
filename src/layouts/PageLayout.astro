---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MessengerFab from '../components/MessengerFab.astro';
import AIAssistant from '../components/AIAssistant.astro';
import StickyMobileCTA from '../components/StickyMobileCTA.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
}

const { title, description, image, noindex } = Astro.props;
---

<BaseLayout title={title} description={description} image={image} noindex={noindex}>
  <Header />
  <main id="main">
    <slot />
  </main>
  <Footer />
  <MessengerFab />
  <AIAssistant />
  <StickyMobileCTA />
</BaseLayout>
